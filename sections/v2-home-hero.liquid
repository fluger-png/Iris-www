{%- liquid
  assign hero_images_count = 0
  if section.settings.image_1 != blank
    assign hero_images_count = hero_images_count | plus: 1
  endif
  if section.settings.image_2 != blank
    assign hero_images_count = hero_images_count | plus: 1
  endif
  if section.settings.image_3 != blank
    assign hero_images_count = hero_images_count | plus: 1
  endif
-%}

{%- style -%}
  .v2-home-hero-{{ section.id }} {
    --v2-gold: #c9a84c;
    --v2-gold-light: #e8cc7a;
    --v2-gold-dim: #7a6330;
    --v2-black: #080808;
    --v2-surface: #0e0e0e;
    --v2-border: rgba(201, 168, 76, 0.15);
    --v2-text: #ede8df;
    --v2-text-mid: #a89f90;
    --v2-text-dim: #6e685e;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(201, 168, 76, 0.11), transparent 28%),
      linear-gradient(180deg, #0b0b0b 0%, #080808 100%);
    color: var(--v2-text);
  }

  .v2-home-hero-{{ section.id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.45;
    pointer-events: none;
  }

  .v2-home-hero__grid-{{ section.id }} {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: min(96vh, 980px);
  }

  .v2-home-hero__copy-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 15rem 7.5rem 7rem;
  }

  .v2-home-hero__eyebrow-{{ section.id }} {
    margin: 0 0 2.4rem;
    color: var(--v2-gold-dim);
    font-size: 1rem;
    letter-spacing: 0.45rem;
    text-transform: uppercase;
    font-family: var(--font-body-family);
  }

  .v2-home-hero__title-{{ section.id }} {
    margin: 0 0 2.6rem;
    max-width: 64rem;
    color: var(--v2-text);
    font-family: var(--font-heading-family);
    font-size: clamp(4.8rem, 7vw, 9.4rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: 0.03em;
  }

  .v2-home-hero__title-{{ section.id }} em,
  .v2-home-hero__title-{{ section.id }} em * {
    color: var(--v2-gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-home-hero__description-{{ section.id }} {
    margin: 0 0 3.6rem;
    max-width: 52rem;
    color: var(--v2-text-mid);
    font-size: 1.8rem;
    line-height: 1.8;
    font-family: var(--font-body-family);
  }

  .v2-home-hero__actions-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    margin-bottom: 3rem;
  }

  .v2-home-hero__button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.6rem;
    padding: 1.6rem 3rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.24rem;
    font-size: 1.1rem;
    font-family: var(--font-body-family);
    transition: all 0.25s ease;
  }

  .v2-home-hero__button-{{ section.id }}.is-primary {
    background: var(--v2-gold);
    color: #080808;
  }

  .v2-home-hero__button-{{ section.id }}.is-primary:hover {
    background: var(--v2-gold-light);
  }

  .v2-home-hero__button-{{ section.id }}.is-secondary {
    border: 1px solid var(--v2-border);
    color: var(--v2-gold);
    background: rgba(201, 168, 76, 0.04);
  }

  .v2-home-hero__button-{{ section.id }}.is-secondary:hover {
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(201, 168, 76, 0.08);
  }

  .v2-home-hero__meta-{{ section.id }} {
    color: var(--v2-text-dim);
    font-size: 1rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
    font-family: var(--font-body-family);
  }

  .v2-home-hero__meta-{{ section.id }} strong {
    color: var(--v2-gold);
    font-size: 1.5rem;
    letter-spacing: 0.08rem;
  }

  .v2-home-hero__visual-{{ section.id }} {
    position: relative;
    min-height: 54rem;
    overflow: hidden;
    border-left: 1px solid var(--v2-border);
    background: #111;
  }

  .v2-home-hero__slides-{{ section.id }} {
    position: absolute;
    inset: 0;
  }

  .v2-home-hero__slide-{{ section.id }} {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .v2-home-hero__slide-{{ section.id }}.is-active {
    opacity: 1;
  }

  .v2-home-hero__slide-{{ section.id }} img,
  .v2-home-hero__placeholder-{{ section.id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .v2-home-hero__placeholder-{{ section.id }} {
    background: linear-gradient(145deg, rgba(201, 168, 76, 0.12), rgba(255,255,255,0.02));
  }

  .v2-home-hero__overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(8, 8, 8, 0.08) 0%, rgba(8, 8, 8, 0.26) 100%),
      linear-gradient(90deg, transparent 35%, rgba(8, 8, 8, 0.44) 100%);
    pointer-events: none;
  }

  .v2-home-hero__caption-{{ section.id }} {
    position: absolute;
    left: 3rem;
    right: 3rem;
    bottom: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.6rem;
    color: #f6f1e8;
    z-index: 2;
  }

  .v2-home-hero__caption-label-{{ section.id }} {
    font-size: 1rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    color: rgba(246, 241, 232, 0.72);
    font-family: var(--font-body-family);
  }

  .v2-home-hero__caption-title-{{ section.id }} {
    margin-top: 0.8rem;
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 2.6vw, 3.8rem);
    line-height: 1.1;
  }

  .v2-home-hero__dots-{{ section.id }} {
    display: flex;
    gap: 0.8rem;
  }

  .v2-home-hero__dot-{{ section.id }} {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    border: 1px solid rgba(246, 241, 232, 0.45);
    background: transparent;
    cursor: pointer;
    padding: 0;
  }

  .v2-home-hero__dot-{{ section.id }}.is-active {
    background: var(--v2-gold);
    border-color: var(--v2-gold);
  }

  @media screen and (max-width: 989px) {
    .v2-home-hero__grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .v2-home-hero__copy-{{ section.id }} {
      order: 2;
      padding: 4rem 2.4rem 5rem;
    }

    .v2-home-hero__visual-{{ section.id }} {
      order: 1;
      min-height: 48rem;
      border-left: 0;
      border-bottom: 1px solid var(--v2-border);
    }
  }

  @media screen and (max-width: 749px) {
    .v2-home-hero__copy-{{ section.id }} {
      padding: 3.4rem 2rem 4rem;
    }

    .v2-home-hero__eyebrow-{{ section.id }} {
      font-size: 0.9rem;
      letter-spacing: 0.32rem;
      margin-bottom: 1.8rem;
    }

    .v2-home-hero__title-{{ section.id }} {
      font-size: clamp(3.8rem, 11vw, 5.8rem);
      margin-bottom: 2rem;
    }

    .v2-home-hero__description-{{ section.id }} {
      font-size: 1.6rem;
      line-height: 1.7;
      margin-bottom: 2.8rem;
    }

    .v2-home-hero__actions-{{ section.id }} {
      flex-direction: column;
      align-items: stretch;
      margin-bottom: 2.4rem;
    }

    .v2-home-hero__button-{{ section.id }} {
      width: 100%;
    }

    .v2-home-hero__visual-{{ section.id }} {
      min-height: 42rem;
    }

    .v2-home-hero__caption-{{ section.id }} {
      left: 2rem;
      right: 2rem;
      bottom: 2rem;
      flex-direction: column;
      align-items: flex-start;
    }
  }
{%- endstyle -%}

<section class="v2-home-hero-{{ section.id }}">
  <div class="v2-home-hero__grid-{{ section.id }}">
    <div class="v2-home-hero__copy-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="v2-home-hero__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="v2-home-hero__title-{{ section.id }}">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="v2-home-hero__description-{{ section.id }}">{{ section.settings.description }}</div>
      {%- endif -%}

      <div class="v2-home-hero__actions-{{ section.id }}">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="v2-home-hero__button-{{ section.id }} is-primary"
            href="{{ section.settings.primary_link | default: '/products/iris-the-unseen-edition' }}"
          >
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_label != blank -%}
          <a
            class="v2-home-hero__button-{{ section.id }} is-secondary"
            href="{{ section.settings.secondary_link | default: '/pages/iris-archive' }}"
          >
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.meta_text != blank -%}
        <p class="v2-home-hero__meta-{{ section.id }}">{{ section.settings.meta_text }}</p>
      {%- endif -%}
    </div>

    <div class="v2-home-hero__visual-{{ section.id }}">
      <div class="v2-home-hero__slides-{{ section.id }}" data-v2-home-hero-slides>
        {%- if hero_images_count == 0 -%}
          <div class="v2-home-hero__slide-{{ section.id }} is-active">
            <div class="v2-home-hero__placeholder-{{ section.id }}">
              {{ 'lifestyle-1' | placeholder_svg_tag }}
            </div>
          </div>
        {%- else -%}
          {%- for index in (1..3) -%}
            {%- liquid
              assign image_key = 'image_' | append: index
              assign hero_image = section.settings[image_key]
            -%}
            {%- if hero_image != blank -%}
              <div class="v2-home-hero__slide-{{ section.id }}{% if forloop.first %} is-active{% endif %}" data-v2-home-hero-slide>
                {{
                  hero_image
                  | image_url: width: 2400
                  | image_tag:
                    loading: 'eager',
                    widths: '750, 1100, 1500, 2000, 2400',
                    sizes: '(min-width: 990px) 50vw, 100vw'
                }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="v2-home-hero__overlay-{{ section.id }}"></div>

      <div class="v2-home-hero__caption-{{ section.id }}">
        <div>
          <div class="v2-home-hero__caption-label-{{ section.id }}">{{ section.settings.visual_eyebrow }}</div>
          <div class="v2-home-hero__caption-title-{{ section.id }}">{{ section.settings.visual_title }}</div>
        </div>

        {%- if hero_images_count > 1 -%}
          <div class="v2-home-hero__dots-{{ section.id }}" data-v2-home-hero-dots>
            {%- for index in (1..3) -%}
              {%- liquid
                assign image_key = 'image_' | append: index
                assign hero_image = section.settings[image_key]
              -%}
              {%- if hero_image != blank -%}
                <button
                  type="button"
                  class="v2-home-hero__dot-{{ section.id }}{% if forloop.first %} is-active{% endif %}"
                  data-v2-home-hero-dot="{{ forloop.index0 }}"
                  aria-label="Show image {{ forloop.index }}"
                ></button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('.v2-home-hero-{{ section.id }}');
    if (!root) return;

    var slides = Array.prototype.slice.call(root.querySelectorAll('[data-v2-home-hero-slide]'));
    var dots = Array.prototype.slice.call(root.querySelectorAll('[data-v2-home-hero-dot]'));

    if (slides.length < 2) return;

    var activeIndex = 0;
    var timer = null;

    function render(index) {
      activeIndex = index;
      slides.forEach(function (slide, slideIndex) {
        slide.classList.toggle('is-active', slideIndex === index);
      });
      dots.forEach(function (dot, dotIndex) {
        dot.classList.toggle('is-active', dotIndex === index);
      });
    }

    function start() {
      stop();
      timer = window.setInterval(function () {
        render((activeIndex + 1) % slides.length);
      }, 4200);
    }

    function stop() {
      if (timer) {
        window.clearInterval(timer);
        timer = null;
      }
    }

    dots.forEach(function (dot, index) {
      dot.addEventListener('click', function () {
        render(index);
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    start();
  })();
</script>

{% schema %}
{
  "name": "V2 Home Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "IRIS NYC"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "A new form of <em>collectible art</em>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Each IRIS is assigned in mystery, revealed through ownership, and anchored by physical gold. The object becomes fully known only when it becomes yours.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Acquire IRIS"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View Revealed Archive"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "inline_richtext",
      "id": "meta_text",
      "label": "Meta text",
      "default": "Current release <strong>$199</strong> &nbsp;&nbsp; 10,000 total works"
    },
    {
      "type": "text",
      "id": "visual_eyebrow",
      "label": "Visual eyebrow",
      "default": "Edition Preview"
    },
    {
      "type": "text",
      "id": "visual_title",
      "label": "Visual title",
      "default": "The unseen edition"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    }
  ],
  "presets": [
    {
      "name": "V2 Home Hero"
    }
  ]
}
{% endschema %}
