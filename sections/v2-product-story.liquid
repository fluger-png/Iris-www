{%- style -%}
  .v2-product-story-{{ section.id }} {
    --v2-gold: #c9a84c;
    --v2-gold-dim: #7a6330;
    --v2-surface: #000000;
    --v2-surface-2: #121212;
    --v2-border: rgba(201, 168, 76, 0.15);
    --v2-text: #ede8df;
    --v2-text-mid: #a89f90;
    background: #000000;
    color: var(--v2-text);
    border-top: 1px solid var(--v2-border);
  }

  .v2-product-story__wrap-{{ section.id }} {
    max-width: 128rem;
    margin: 0 auto;
    padding: 12rem 8rem;
  }

  .v2-product-story__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    gap: 8rem;
    align-items: start;
  }

  .v2-product-story__media-{{ section.id }} {
    position: relative;
  }

  .v2-product-story__frame-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: var(--v2-surface-2);
    border: 1px solid var(--v2-border);
    box-shadow: 0 4rem 10rem rgba(0, 0, 0, 0.45);
    padding: 3.6rem;
    aspect-ratio: 1 / 1;
  }

  .v2-product-story__image-{{ section.id }} {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center center;
    background: #1a1a1a;
  }

  .v2-product-story__badge-{{ section.id }} {
    position: absolute;
    top: 2.4rem;
    right: 2.4rem;
    z-index: 2;
    padding: 1rem 1.5rem;
    border: 1px solid var(--v2-border);
    background: rgba(8, 8, 8, 0.82);
    color: var(--v2-gold);
    text-transform: uppercase;
    letter-spacing: 0.22rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
  }

  .v2-product-story__content-{{ section.id }} {
    padding-top: 2.4rem;
  }

  .v2-product-story__eyebrow-{{ section.id }} {
    margin: 0 0 1.8rem;
    color: var(--v2-gold-dim);
    text-transform: uppercase;
    letter-spacing: 0.42rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
  }

  .v2-product-story__title-{{ section.id }} {
    margin: 0 0 2.4rem;
    font-family: var(--font-heading-family);
    font-size: clamp(3.6rem, 4.4vw, 5.8rem);
    line-height: 1.06;
    letter-spacing: 0.03em;
    font-weight: 400;
    color: var(--v2-text) !important;
  }

  .v2-product-story__title-{{ section.id }},
  .v2-product-story__title-{{ section.id }} * {
    color: var(--v2-text) !important;
  }

  .v2-product-story__title-{{ section.id }} em,
  .v2-product-story__title-{{ section.id }} em * {
    color: var(--v2-gold) !important;
    font-style: italic;
    font-weight: 400;
  }

  .v2-product-story__body-{{ section.id }} {
    color: var(--v2-text-mid);
    font-size: 1.75rem;
    line-height: 1.86;
    margin-bottom: 3rem;
  }

  .v2-product-story__body-{{ section.id }},
  .v2-product-story__body-{{ section.id }} *,
  .v2-product-story__price-value-{{ section.id }},
  .v2-product-story__price-note-{{ section.id }} {
    color: inherit;
  }

  .v2-product-story__rule-{{ section.id }} {
    width: 4.2rem;
    height: 1px;
    background: var(--v2-gold);
    margin: 0 0 3rem;
  }

  .v2-product-story__features-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 3.6rem;
    display: grid;
    gap: 1.7rem;
  }

  .v2-product-story__features-{{ section.id }} li {
    display: flex;
    align-items: flex-start;
    gap: 1.4rem;
    color: var(--v2-text-mid);
    font-size: 1.6rem;
    line-height: 1.7;
  }

  .v2-product-story__features-{{ section.id }} li::before {
    content: "—";
    color: var(--v2-gold);
    font-family: var(--font-body-family);
    flex-shrink: 0;
  }

  .v2-product-story__footer-{{ section.id }} {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .v2-product-story__price-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .v2-product-story__price-value-{{ section.id }} {
    font-family: var(--font-heading-family);
    font-size: clamp(3.6rem, 4vw, 5rem);
    line-height: 1;
  }

  .v2-product-story__price-note-{{ section.id }} {
    color: var(--v2-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
  }

  .v2-product-story__cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.6rem;
    padding: 1.6rem 3rem;
    background: var(--v2-gold);
    color: #080808;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.24rem;
    font-size: 1.1rem;
    font-family: var(--font-body-family);
    transition: background 0.25s ease;
  }

  .v2-product-story__cta-{{ section.id }}:hover {
    background: #e8cc7a;
  }

  @media screen and (max-width: 989px) {
    .v2-product-story__wrap-{{ section.id }} {
      padding: 9rem 3.2rem;
    }

    .v2-product-story__grid-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .v2-product-story__content-{{ section.id }} {
      padding-top: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .v2-product-story__wrap-{{ section.id }} {
      padding: 7rem 2rem;
    }

    .v2-product-story__badge-{{ section.id }} {
      top: 1.6rem;
      right: 1.6rem;
      font-size: 0.9rem;
      letter-spacing: 0.16rem;
    }

    .v2-product-story__frame-{{ section.id }} {
      padding: 2rem;
    }

    .v2-product-story__eyebrow-{{ section.id }} {
      letter-spacing: 0.28rem;
      font-size: 0.9rem;
    }

    .v2-product-story__body-{{ section.id }} {
      font-size: 1.6rem;
      line-height: 1.8;
    }

    .v2-product-story__features-{{ section.id }} li {
      font-size: 1.5rem;
    }

    .v2-product-story__footer-{{ section.id }} {
      align-items: stretch;
    }

    .v2-product-story__cta-{{ section.id }} {
      width: 100%;
    }
  }
{%- endstyle -%}

<section class="v2-product-story-{{ section.id }}">
  <div class="v2-product-story__wrap-{{ section.id }}">
    <div class="v2-product-story__grid-{{ section.id }}">
      <div class="v2-product-story__media-{{ section.id }}">
        {%- if section.settings.badge != blank -%}
          <div class="v2-product-story__badge-{{ section.id }}">{{ section.settings.badge }}</div>
        {%- endif -%}

        <div class="v2-product-story__frame-{{ section.id }}">
          {%- if section.settings.image != blank -%}
            {%- assign image_class = 'v2-product-story__image-' | append: section.id -%}
            {{
              section.settings.image
              | image_url: width: 2200
              | image_tag:
                class: image_class,
                loading: 'lazy',
                widths: '750, 1100, 1500, 2000, 2200',
                sizes: '(min-width: 990px) 46vw, 100vw'
            }}
          {%- else -%}
            {%- assign placeholder_class = 'v2-product-story__image-' | append: section.id -%}
            {{ 'image' | placeholder_svg_tag: placeholder_class }}
          {%- endif -%}
        </div>
      </div>

      <div class="v2-product-story__content-{{ section.id }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="v2-product-story__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="v2-product-story__title-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="v2-product-story__body-{{ section.id }}">{{ section.settings.body }}</div>
        {%- endif -%}

        <div class="v2-product-story__rule-{{ section.id }}"></div>

        <ul class="v2-product-story__features-{{ section.id }}">
          {%- for index in (1..4) -%}
            {%- liquid
              assign key = 'feature_' | append: index
              assign value = section.settings[key]
            -%}
            {%- if value != blank -%}
              <li>{{ value }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        <div class="v2-product-story__footer-{{ section.id }}">
          <div class="v2-product-story__price-{{ section.id }}">
            <div class="v2-product-story__price-value-{{ section.id }}">{{ section.settings.price }}</div>
            <div class="v2-product-story__price-note-{{ section.id }}">{{ section.settings.price_note }}</div>
          </div>

          {%- if section.settings.button_label != blank -%}
            <a
              class="v2-product-story__cta-{{ section.id }}"
              href="{{ section.settings.button_link | default: '/products/iris-the-unseen-edition' }}"
            >
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "V2 Product Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Physical work · NFC linked"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Object"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "A physical artwork revealed through <em>ownership</em>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>IRIS is designed as a collectible ritual. You do not select the exact artwork in advance. The image is disclosed only after purchase and activation, turning ownership itself into part of the reveal.</p><p>Every piece carries a trace of 24K gold, an NFC connection, and a rarity assignment committed on-chain through a public Merkle proof process.</p>"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "10,000 total physical works across the full edition."
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Each IRIS is linked to a unique digital passport."
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Rarity is pre-committed and publicly verifiable."
    },
    {
      "type": "text",
      "id": "feature_4",
      "label": "Feature 4",
      "default": "The final reveal happens only after activation."
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$120"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Price note",
      "default": "Current release price"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Edition"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "V2 Product Story"
    }
  ]
}
{% endschema %}
