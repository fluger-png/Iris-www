                <circle cx="32" cy="32" r="5.5" fill="currentColor"/>
              </svg>
            </div>
            <div class="cc-float-card__label">Edition {{ n }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="cc-ticker" aria-hidden="true">
