            </select>
          </div>
          <div class="cc-form-field cc-form-field--full">
            <label class="cc-form-label" for="CollaborateIdea-{{ section.id }}">Tell us about your concept</label>
            <textarea class="cc-form-input" id="CollaborateIdea-{{ section.id }}" name="contact[body]" placeholder="Describe your artwork, your audience, and what you're hoping to create with IRIS...">{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>
          <div class="cc-form-field cc-form-field--full">
            <label class="cc-form-label" for="CollaborateWebsite-{{ section.id }}">Website or Portfolio (optional)</label>
            <input class="cc-form-input" id="CollaborateWebsite-{{ section.id }}" type="text" name="contact[website]" placeholder="https://yourwebsite.com">
          </div>
          <div class="cc-form-submit">
            <button class="cc-button cc-button--gold" type="submit">Submit Application</button>
          </div>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>
<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var tabButtons = root.querySelectorAll('.cc-tab-button');
    var tabPanels = root.querySelectorAll('.cc-tab-panel');
    tabButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        var target = button.getAttribute('data-target');
        tabButtons.forEach(function (btn) {
          btn.classList.toggle('is-active', btn === button);
        });
        tabPanels.forEach(function (panel) {
          panel.classList.toggle('is-active', panel.getAttribute('data-panel') === target);
        });
      });
    });

    var faqItems = root.querySelectorAll('.cc-faq-item');
    faqItems.forEach(function (item) {
      var toggle = item.querySelector('.cc-faq-toggle');
      var body = item.querySelector('.cc-faq-body');
      if (!toggle || !body) return;
      toggle.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        faqItems.forEach(function (other) {
          other.classList.remove('is-open');
          var otherBody = other.querySelector('.cc-faq-body');
          if (otherBody) otherBody.style.maxHeight = '0px';
        });
        if (!isOpen) {
          item.classList.add('is-open');
          body.style.maxHeight = body.scrollHeight + 'px';
        }
      });
    });
  })();
</script>

