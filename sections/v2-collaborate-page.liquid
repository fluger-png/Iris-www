        <span class="cc-ticker__item"><span class="cc-ticker__dot"></span>Collector activation flow</span>
        <span class="cc-ticker__item"><span class="cc-ticker__dot"></span>Public archive visibility</span>
        <span class="cc-ticker__item"><span class="cc-ticker__dot"></span>Revenue share structure</span>
      {%- endfor -%}
    </div>
  </div>

  <div class="cc-section page-width">
