{%- assign collaborate_form_id = 'CollaborateForm-' | append: section.id -%}
{%- style -%}
  .v2-collab-{{ section.id }} {
    --gold: #c9a84c;
    --gold-light: #e8cc7a;
    --gold-dim: #7a6330;
    --gold-faint: rgba(201, 168, 76, 0.08);
    --black: #080808;
    --surface: #0f0f0f;
    --surface-2: #151515;
    --text: #ede8df;
    --text-mid: #a89f90;
    --text-dim: #6e685e;
    --border: rgba(201, 168, 76, 0.15);
    background: var(--black);
    color: var(--text);
    overflow: hidden;
  }

  .v2-collab-{{ section.id }} *,
  .v2-collab-{{ section.id }} *::before,
  .v2-collab-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .v2-collab-{{ section.id }} .page-width {
    max-width: 142rem;
  }

  .v2-collab-{{ section.id }} .cc-section {
    padding: 11rem 0;
    border-top: 1px solid var(--border);
  }

  .v2-collab-{{ section.id }} .cc-section--surface {
    background: var(--surface);
  }

  .v2-collab-{{ section.id }} .cc-eyebrow {
    margin: 0 0 1.8rem;
    color: var(--gold-dim);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.42rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-title {
    margin: 0;
    color: var(--text);
    font-family: var(--font-heading-family);
    font-size: clamp(4rem, 5vw, 7rem);
    line-height: 1.05;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .v2-collab-{{ section.id }} .cc-title em {
    color: var(--gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-collab-{{ section.id }} .cc-copy {
    color: var(--text-mid);
    font-size: 1.9rem;
    line-height: 1.8;
  }

  .v2-collab-{{ section.id }} .cc-copy--large {
    font-size: 2rem;
  }

  .v2-collab-{{ section.id }} .cc-button-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 4.8rem;
  }

  .v2-collab-{{ section.id }} .cc-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 7.2rem;
    min-width: 30rem;
    padding: 1.8rem 3rem;
    text-decoration: none;
    font-family: var(--font-body-family);
    font-size: 1.14rem;
    letter-spacing: 0.34rem;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  .v2-collab-{{ section.id }} .cc-button--gold {
    background: var(--gold);
    color: var(--black);
    border: 1px solid var(--gold);
  }

  .v2-collab-{{ section.id }} .cc-button--gold:hover {
    background: var(--gold-light);
    border-color: var(--gold-light);
  }

  .v2-collab-{{ section.id }} .cc-button--ghost {
    color: var(--gold);
    border: 1px solid var(--border);
    background: transparent;
  }

  .v2-collab-{{ section.id }} .cc-button--ghost:hover {
    border-color: var(--gold);
    background: var(--gold-faint);
  }

  .v2-collab-{{ section.id }} .cc-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .v2-collab-{{ section.id }} .cc-hero__copy,
  .v2-collab-{{ section.id }} .cc-hero__visual {
    padding: 14rem 8rem 8rem;
  }

  .v2-collab-{{ section.id }} .cc-hero__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .v2-collab-{{ section.id }} .cc-hero__visual {
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-collab-{{ section.id }} .cc-hero-grid {
    width: 100%;
    max-width: 60rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.3rem;
  }

  .v2-collab-{{ section.id }} .cc-hero-card {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--border);
    overflow: hidden;
    background: #142321;
  }

  .v2-collab-{{ section.id }} .cc-hero-card:nth-child(2) { background: #1a1730; }
  .v2-collab-{{ section.id }} .cc-hero-card:nth-child(3) { background: #2b1613; }
  .v2-collab-{{ section.id }} .cc-hero-card:nth-child(4) { background: #101f3b; }

  .v2-collab-{{ section.id }} .cc-hero-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(135deg, rgba(201,168,76,0.18) 0, rgba(201,168,76,0.18) 1px, transparent 1px, transparent 14px);
    background-size: 18px 18px;
    opacity: 0.35;
  }

  .v2-collab-{{ section.id }} .cc-hero-card::after {
    content: '';
    position: absolute;
    top: 1.4rem;
    right: 1.4rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.8;
  }

  .v2-collab-{{ section.id }} .cc-hero-card__eye {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--gold);
    opacity: 0.8;
  }

  .v2-collab-{{ section.id }} .cc-hero-card__eye svg {
    width: 5.6rem;
    height: 5.6rem;
  }

  .v2-collab-{{ section.id }} .cc-hero-card__label {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1.4rem;
    text-align: center;
    color: rgba(255,255,255,0.42);
    font-family: var(--font-body-family);
    font-size: 0.78rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-hero-note {
    margin-top: 2.6rem;
    color: var(--text-dim);
    text-align: center;
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.24rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-ticker {
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.8rem 0;
  }

  .v2-collab-{{ section.id }} .cc-ticker__track {
    display: flex;
    gap: 3.6rem;
    min-width: max-content;
    align-items: center;
    animation: ccTicker 38s linear infinite;
  }

  .v2-collab-{{ section.id }} .cc-ticker__item {
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
  }

  .v2-collab-{{ section.id }} .cc-ticker__item em {
    color: var(--text);
    font-style: italic;
    font-weight: 400;
  }

  .v2-collab-{{ section.id }} .cc-ticker__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  @keyframes ccTicker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .v2-collab-{{ section.id }} .cc-tabs {
    margin-top: 6rem;
  }

  .v2-collab-{{ section.id }} .cc-tab-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.2rem;
  }

  .v2-collab-{{ section.id }} .cc-tab-button {
    min-height: 7rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .v2-collab-{{ section.id }} .cc-tab-button.is-active {
    color: var(--gold);
    background: var(--gold-faint);
    box-shadow: inset 0 -2px 0 0 var(--gold);
  }

  .v2-collab-{{ section.id }} .cc-tab-panel {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 0.2rem;
  }

  .v2-collab-{{ section.id }} .cc-tab-panel.is-active {
    display: grid;
  }

  .v2-collab-{{ section.id }} .cc-tab-copy,
  .v2-collab-{{ section.id }} .cc-tab-math,
  .v2-collab-{{ section.id }} .cc-tier,
  .v2-collab-{{ section.id }} .cc-process-step,
  .v2-collab-{{ section.id }} .cc-support-card,
  .v2-collab-{{ section.id }} .cc-scenario,
  .v2-collab-{{ section.id }} .cc-math-card,
  .v2-collab-{{ section.id }} .cc-faq,
  .v2-collab-{{ section.id }} .cc-form-wrap {
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.015);
  }

  .v2-collab-{{ section.id }} .cc-tab-copy,
  .v2-collab-{{ section.id }} .cc-tab-math,
  .v2-collab-{{ section.id }} .cc-tier,
  .v2-collab-{{ section.id }} .cc-process-step,
  .v2-collab-{{ section.id }} .cc-support-card,
  .v2-collab-{{ section.id }} .cc-scenario,
  .v2-collab-{{ section.id }} .cc-math-card,
  .v2-collab-{{ section.id }} .cc-form-wrap {
    padding: 4rem;
  }

  .v2-collab-{{ section.id }} .cc-tab-copy {
    min-height: 100%;
  }

  .v2-collab-{{ section.id }} .cc-tab-list {
    margin: 3.4rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .v2-collab-{{ section.id }} .cc-tab-list li {
    display: flex;
    gap: 1.4rem;
    color: var(--text-mid);
    font-size: 1.65rem;
    line-height: 1.8;
  }

  .v2-collab-{{ section.id }} .cc-tab-list li::before {
    content: '–';
    color: var(--gold);
    flex-shrink: 0;
  }

  .v2-collab-{{ section.id }} .cc-tab-math {
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
    display: flex;
    flex-direction: column;
    justify-content: end;
    gap: 2rem;
    min-height: 100%;
  }

  .v2-collab-{{ section.id }} .cc-tab-math__big {
    font-family: var(--font-heading-family);
    font-size: clamp(5rem, 5vw, 7rem);
    line-height: 1;
    color: var(--gold);
  }

  .v2-collab-{{ section.id }} .cc-tab-math__small {
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 0.98rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    line-height: 1.8;
  }

  .v2-collab-{{ section.id }} .cc-process-line {
    position: relative;
    margin-top: 7rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.6rem;
  }

  .v2-collab-{{ section.id }} .cc-process-line::before {
    content: '';
    position: absolute;
    left: 7%;
    right: 7%;
    top: 5.2rem;
    height: 1px;
    background: var(--border);
  }

  .v2-collab-{{ section.id }} .cc-process-step {
    text-align: center;
    background: transparent;
    border: 0;
    padding: 0 0.8rem;
  }

  .v2-collab-{{ section.id }} .cc-process-step__circle {
    width: 9rem;
    height: 9rem;
    margin: 0 auto 2.2rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--black);
    display: grid;
    place-items: center;
    color: var(--gold);
    position: relative;
    z-index: 1;
  }

  .v2-collab-{{ section.id }} .cc-process-step__circle svg {
    width: 3.2rem;
    height: 3.2rem;
  }

  .v2-collab-{{ section.id }} .cc-process-step__num {
    color: var(--gold-dim);
    font-family: var(--font-body-family);
    font-size: 0.92rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .v2-collab-{{ section.id }} .cc-process-step__title,
  .v2-collab-{{ section.id }} .cc-support-card__title,
  .v2-collab-{{ section.id }} .cc-faq-question {
    color: var(--text);
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.24;
  }

  .v2-collab-{{ section.id }} .cc-process-step__desc,
  .v2-collab-{{ section.id }} .cc-support-card__list li,
  .v2-collab-{{ section.id }} .cc-scenario__copy,
  .v2-collab-{{ section.id }} .cc-faq-answer,
  .v2-collab-{{ section.id }} .cc-form-input,
  .v2-collab-{{ section.id }} .cc-form-select {
    color: var(--text-dim);
    font-size: 1.45rem;
    line-height: 1.8;
  }

  .v2-collab-{{ section.id }} .cc-grid-3 {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.2rem;
  }

  .v2-collab-{{ section.id }} .cc-tier {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .v2-collab-{{ section.id }} .cc-tier--featured {
    box-shadow: inset 0 0 0 1px rgba(201, 168, 76, 0.35);
  }

  .v2-collab-{{ section.id }} .cc-tier__badge {
    align-self: flex-end;
    padding: 0.8rem 1.6rem;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-body-family);
    font-size: 0.8rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    margin: -4rem -4rem 2.8rem auto;
  }

  .v2-collab-{{ section.id }} .cc-tier__eyebrow,
  .v2-collab-{{ section.id }} .cc-scenario__eyebrow,
  .v2-collab-{{ section.id }} .cc-form-label,
  .v2-collab-{{ section.id }} .cc-faq-eyebrow,
  .v2-collab-{{ section.id }} .cc-math-card__eyebrow {
    color: var(--gold-dim);
    font-family: var(--font-body-family);
    font-size: 0.92rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-tier__big {
    margin-top: 2rem;
    color: var(--text);
    font-family: var(--font-heading-family);
    font-size: clamp(5rem, 5vw, 7rem);
    line-height: 1;
  }

  .v2-collab-{{ section.id }} .cc-tier__body {
    padding-top: 4rem;
    border-top: 1px solid var(--border);
    margin-top: 3.2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .v2-collab-{{ section.id }} .cc-tier__copy {
    color: var(--text-mid);
    font-size: 1.7rem;
    line-height: 1.9;
  }

  .v2-collab-{{ section.id }} .cc-tier__list {
    list-style: none;
    padding: 0;
    margin: 3.4rem 0;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .v2-collab-{{ section.id }} .cc-tier__list li {
    display: flex;
    gap: 1.1rem;
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.16rem;
    text-transform: uppercase;
    line-height: 1.7;
  }

  .v2-collab-{{ section.id }} .cc-tier__list li::before {
    content: '✓';
    color: var(--gold);
    flex-shrink: 0;
  }

  .v2-collab-{{ section.id }} .cc-tier__earnings {
    margin-top: auto;
    padding: 2.2rem 2.4rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.015);
  }

  .v2-collab-{{ section.id }} .cc-tier__earnings-value {
    margin-top: 1rem;
    color: var(--gold);
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
  }

  .v2-collab-{{ section.id }} .cc-tier__earnings-note {
    margin-top: 1rem;
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.14rem;
    text-transform: uppercase;
    line-height: 1.7;
  }

  .v2-collab-{{ section.id }} .cc-tier__cta {
    margin-top: 2.2rem;
  }

  .v2-collab-{{ section.id }} .cc-math {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
    gap: 8rem;
    align-items: center;
    margin-top: 6rem;
  }

  .v2-collab-{{ section.id }} .cc-math-card__bars {
    margin-top: 3.6rem;
    display: grid;
    gap: 2rem;
  }

  .v2-collab-{{ section.id }} .cc-math-card__bar-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    align-items: center;
  }

  .v2-collab-{{ section.id }} .cc-math-card__track {
    height: 4rem;
    background: rgba(255,255,255,0.05);
    overflow: hidden;
  }

  .v2-collab-{{ section.id }} .cc-math-card__fill {
    height: 100%;
    display: flex;
    align-items: center;
    padding-left: 1.6rem;
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.14rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-math-card__fill--you {
    width: 70%;
    background: linear-gradient(to right, var(--gold-dim), var(--gold));
    color: var(--black);
  }

  .v2-collab-{{ section.id }} .cc-math-card__fill--iris {
    width: 30%;
    background: rgba(255,255,255,0.08);
    color: var(--text-mid);
  }

  .v2-collab-{{ section.id }} .cc-math-card__footer {
    margin-top: 3.6rem;
    padding-top: 2.4rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 0.98rem;
    letter-spacing: 0.14rem;
    text-transform: uppercase;
    line-height: 1.9;
  }

  .v2-collab-{{ section.id }} .cc-math-cases {
    margin-top: 4rem;
    display: grid;
    gap: 0.2rem;
  }

  .v2-collab-{{ section.id }} .cc-math-case {
    padding: 2.8rem 3.2rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.015);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: center;
  }

  .v2-collab-{{ section.id }} .cc-math-case__left {
    color: var(--text);
    font-family: var(--font-heading-family);
    font-size: 1.9rem;
  }

  .v2-collab-{{ section.id }} .cc-math-case__meta {
    margin-top: 0.8rem;
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.14rem;
    text-transform: uppercase;
    line-height: 1.7;
  }

  .v2-collab-{{ section.id }} .cc-math-case__value {
    color: var(--gold);
    font-family: var(--font-heading-family);
    font-size: 3rem;
    white-space: nowrap;
  }

  .v2-collab-{{ section.id }} .cc-support-card__icon {
    color: var(--gold);
    margin-bottom: 2rem;
  }

  .v2-collab-{{ section.id }} .cc-support-card__icon svg {
    width: 3.4rem;
    height: 3.4rem;
  }

  .v2-collab-{{ section.id }} .cc-support-card__list {
    list-style: none;
    padding: 0;
    margin: 2.8rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .v2-collab-{{ section.id }} .cc-support-card__list li {
    display: flex;
    gap: 1.2rem;
    color: var(--text-dim);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.16rem;
    text-transform: uppercase;
  }

  .v2-collab-{{ section.id }} .cc-support-card__list li::before {
    content: '•';
    color: var(--gold);
    flex-shrink: 0;
  }

  .v2-collab-{{ section.id }} .cc-role-grid {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.2rem;
  }

  .v2-collab-{{ section.id }} .cc-role-card {
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.015);
    padding: 3.6rem 3rem;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .v2-collab-{{ section.id }} .cc-role-num {
    color: var(--gold-dim);
    font-family: var(--font-body-family);
    font-size: 0.92rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
    margin-bottom: 2.6rem;
  }

  .v2-collab-{{ section.id }} .cc-role-icon {
    color: var(--gold);
    margin-bottom: 2.6rem;
  }

  .v2-collab-{{ section.id }} .cc-role-icon svg {
    width: 3.4rem;
    height: 3.4rem;
  }

  .v2-collab-{{ section.id }} .cc-role-title {
    color: var(--text);
    font-family: var(--font-heading-family);
    font-size: 1.95rem;
    line-height: 1.25;
  }

  .v2-collab-{{ section.id }} .cc-role-desc {
    margin-top: 1.8rem;
    color: var(--text-dim);
    font-size: 1.45rem;
    line-height: 1.85;
  }

  .v2-collab-{{ section.id }} .cc-role-note {
