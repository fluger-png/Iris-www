<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var tabButtons = root.querySelectorAll('.cc-tab-button');
    var tabPanels = root.querySelectorAll('.cc-tab-panel');
    tabButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        var target = button.getAttribute('data-target');
        tabButtons.forEach(function (btn) {
          btn.classList.toggle('is-active', btn === button);
        });
        tabPanels.forEach(function (panel) {
          panel.classList.toggle('is-active', panel.getAttribute('data-panel') === target);
        });
      });
    });

    var faqItems = root.querySelectorAll('.cc-faq-item');
    faqItems.forEach(function (item) {
      var toggle = item.querySelector('.cc-faq-toggle');
      var body = item.querySelector('.cc-faq-body');
      if (!toggle || !body) return;
      toggle.addEventListener('click', function () {
        var isOpen = item.classList.contains('is-open');
        faqItems.forEach(function (other) {
          other.classList.remove('is-open');
          var otherBody = other.querySelector('.cc-faq-body');
          if (otherBody) otherBody.style.maxHeight = '0px';
        });
        if (!isOpen) {
          item.classList.add('is-open');
          body.style.maxHeight = body.scrollHeight + 'px';
        }
      });
    });

    var cacheKey = 'iris_goldapi_usd_g';
    var ttl = 8 * 60 * 60 * 1000;

    function money(value, digits) {
      var n = Number(value);
      if (!isFinite(n)) return '$—';
      return '$' + n.toLocaleString('en-US', {
        minimumFractionDigits: digits,
        maximumFractionDigits: digits
      });
    }

    function wholeMoney(value) {
      var n = Number(value);
      if (!isFinite(n)) return '$—';
      return '$' + Math.round(n).toLocaleString('en-US');
    }

    function setAll(selector, text) {
      root.querySelectorAll(selector).forEach(function (el) {
        el.textContent = text;
      });
    }

    function normalizeGoldValue(value) {
      if (value === null || value === undefined) return null;
      if (typeof value === 'number') return isFinite(value) ? value : null;
      var cleaned = String(value).replace(/[^0-9.\-]/g, '');
      var parsed = Number(cleaned);
      return isFinite(parsed) ? parsed : null;
    }

    function readCache() {
      try {
        var raw = localStorage.getItem(cacheKey);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || parsed.value === undefined || !parsed.ts) return null;
        if (Date.now() - parsed.ts > ttl) return null;
        return normalizeGoldValue(parsed.value);
      } catch (e) {
        return null;
      }
    }

    function writeCache(value) {
      try {
        localStorage.setItem(cacheKey, JSON.stringify({ value: value, ts: Date.now() }));
      } catch (e) {}
    }

    function updateFromGold(perGram) {
      var gold = Number(perGram);
      if (!isFinite(gold)) return;
      var goldCost = 0.4 * gold;
      var productionCost = 20.0;
      var costPerUnit = goldCost + productionCost;
      var minPrice = costPerUnit * 1.5;
      var displayMin = Math.round(minPrice);

      function coarseMoney(value) {
        var n = Number(value);
        if (!isFinite(n)) return '$—';
        var step = n >= 100000 ? 10000 : n >= 10000 ? 1000 : 100;
        return '$' + (Math.floor(n / step) * step).toLocaleString('en-US');
      }

      function publicTotal(pieces, share) {
        var salePrice = displayMin;
        var netMargin = salePrice - costPerUnit;
        var partnerEarnPerUnit = netMargin * share;
        return partnerEarnPerUnit * pieces;
      }

      var artistTotal = publicTotal(100, 0.70);
      var studioTotal = publicTotal(1000, 0.75);
      var galleryTotal = publicTotal(10000, 0.80);
      var privateUnitPrice = 100;
      var privateMinimum = privateUnitPrice * 100;

      setAll('[data-collab-gold-price]', money(gold, 2));
      setAll('[data-collab-cost]', money(costPerUnit, 2));
      setAll('[data-collab-min-price]', wholeMoney(displayMin));
      setAll('[data-collab-artist-specs]', '1 artwork · 100 pieces');
      setAll('[data-collab-studio-specs]', '10 artworks · 1,000 pieces');
      setAll('[data-collab-gallery-specs]', '100 artworks · 10,000 pieces');
      setAll('[data-collab-private-specs]', 'Any artwork count · Min. 100 pieces');

      setAll('[data-collab-artist-total]', 'from ' + coarseMoney(artistTotal));
      setAll('[data-collab-studio-total]', 'from ' + coarseMoney(studioTotal));
      setAll('[data-collab-gallery-total]', 'from ' + coarseMoney(galleryTotal));
      setAll('[data-collab-private-total]', wholeMoney(privateUnitPrice));
      setAll('[data-collab-private-cost]', wholeMoney(privateUnitPrice));
      setAll('[data-tier-artist-total]', 'from ' + coarseMoney(artistTotal));
      setAll('[data-tier-studio-total]', 'from ' + coarseMoney(studioTotal));
      setAll('[data-tier-gallery-total]', 'from ' + coarseMoney(galleryTotal));

      setAll('[data-collab-artist-line]', 'Current minimum price: ' + wholeMoney(displayMin) + ' (excl. tax) · 100 pieces · Artist earns 70% of the margin');
      setAll('[data-collab-studio-line]', 'Current minimum price: ' + wholeMoney(displayMin) + ' (excl. tax) · 1,000 pieces · Studio earns 75% of the margin');
      setAll('[data-collab-gallery-line]', 'Current minimum price: ' + wholeMoney(displayMin) + ' (excl. tax) · 10,000 pieces · Gallery earns 80% of the margin');
      setAll('[data-collab-private-line]', 'Current cost per unit: ' + wholeMoney(privateUnitPrice) + ' · 100 pieces minimum · Upfront invoice = cost × quantity');
    }

    function fetchPrice() {
      var cached = readCache();
      if (cached) {
        updateFromGold(cached);
        return;
      }

      fetch('/apps/iris/gold-price', { headers: { 'Accept': 'application/json' } })
        .then(function (res) {
          if (!res.ok) throw new Error('bad_status');
          return res.json();
        })
        .then(function (data) {
          var perGram = Number(data.price_usd_g);
          if (!perGram) throw new Error('missing_price');
          writeCache(perGram);
          updateFromGold(perGram);
        })
        .catch(function () {
          setAll('[data-collab-gold-price]', '$—');
          setAll('[data-collab-cost]', '$—');
          setAll('[data-collab-min-price]', '$—');
        });
    }

    fetchPrice();
  })();
</script>

