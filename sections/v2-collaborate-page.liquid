{%- style -%}
  .v2-collaborate-{{ section.id }} {
    --v2-gold: #c9a84c;
    --v2-gold-light: #e8cc7a;
    --v2-gold-dim: #7a6330;
    --v2-gold-faint: rgba(201, 168, 76, 0.07);
    --v2-black: #080808;
    --v2-surface: #0e0e0e;
    --v2-surface-2: #131313;
    --v2-border: rgba(201, 168, 76, 0.15);
    --v2-border-dim: rgba(255, 255, 255, 0.06);
    --v2-text: #ede8df;
    --v2-text-dim: #6e685e;
    --v2-text-mid: #a89f90;
    background: var(--v2-black);
    color: var(--v2-text);
    overflow: hidden;
  }

  .v2-collaborate-{{ section.id }} *,
  .v2-collaborate-{{ section.id }} *::before,
  .v2-collaborate-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .v2-collaborate-{{ section.id }} .page-width {
    max-width: 128rem;
  }

  .v2-collaborate-{{ section.id }} .cc-section {
    padding: 11rem 0;
  }

  .v2-collaborate-{{ section.id }} .cc-section--surface {
    background: var(--v2-surface);
    border-top: 1px solid var(--v2-border);
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-collaborate-{{ section.id }} .cc-eyebrow {
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.42rem;
    text-transform: uppercase;
    color: var(--v2-gold-dim);
    margin: 0 0 1.8rem;
  }

  .v2-collaborate-{{ section.id }} .cc-title {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: clamp(3rem, 4vw, 5.6rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--v2-text);
    letter-spacing: 0.02em;
  }

  .v2-collaborate-{{ section.id }} .cc-title em {
    color: var(--v2-gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-collaborate-{{ section.id }} .cc-copy {
    color: var(--v2-text-mid);
    font-size: 1.72rem;
    line-height: 1.85;
  }

  .v2-collaborate-{{ section.id }} .cc-btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem;
    margin-top: 4rem;
  }

  .v2-collaborate-{{ section.id }} .cc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.8rem;
    padding: 1.8rem 3.2rem;
    text-decoration: none;
    font-family: var(--font-body-family);
    font-size: 1.08rem;
    letter-spacing: 0.28rem;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .v2-collaborate-{{ section.id }} .cc-btn--gold {
    background: var(--v2-gold);
    color: #080808;
    border: 1px solid var(--v2-gold);
  }

  .v2-collaborate-{{ section.id }} .cc-btn--gold:hover {
    background: var(--v2-gold-light);
    border-color: var(--v2-gold-light);
  }

  .v2-collaborate-{{ section.id }} .cc-btn--outline {
    border: 1px solid var(--v2-border);
    color: var(--v2-gold);
    background: transparent;
  }

  .v2-collaborate-{{ section.id }} .cc-btn--outline:hover {
    border-color: var(--v2-gold);
    background: var(--v2-gold-faint);
  }

  .v2-collaborate-{{ section.id }} .cc-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
  }

  .v2-collaborate-{{ section.id }} .cc-hero__left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 14rem 8rem 8rem;
    position: relative;
    z-index: 1;
  }

  .v2-collaborate-{{ section.id }} .cc-hero__title {
    margin: 0 0 2.8rem;
    font-family: var(--font-heading-family);
    font-size: clamp(4.4rem, 5.2vw, 7.4rem);
    font-weight: 400;
    line-height: 1.04;
    color: var(--v2-text);
  }

  .v2-collaborate-{{ section.id }} .cc-hero__title em {
    color: var(--v2-gold);
    font-style: italic;
  }

  .v2-collaborate-{{ section.id }} .cc-hero__desc {
    max-width: 50rem;
    margin: 0;
    color: var(--v2-text-mid);
    font-size: 1.85rem;
    line-height: 1.85;
  }

  .v2-collaborate-{{ section.id }} .cc-hero__right {
    position: relative;
    background: var(--v2-surface);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14rem 6rem 8rem;
  }

  .v2-collaborate-{{ section.id }} .cc-hero__right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 60% 40%, rgba(201, 168, 76, 0.08), transparent 70%);
    pointer-events: none;
  }

  .v2-collaborate-{{ section.id }} .cc-float-grid {
    width: 100%;
    max-width: 44rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.3rem;
    position: relative;
    z-index: 1;
  }

  .v2-collaborate-{{ section.id }} .cc-float-card {
    position: relative;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--v2-border);
    background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(201,168,76,0.08));
    overflow: hidden;
  }

  .v2-collaborate-{{ section.id }} .cc-float-card:nth-child(2n) {
    background: linear-gradient(135deg, rgba(201,168,76,0.12), rgba(255,255,255,0.03));
  }

  .v2-collaborate-{{ section.id }} .cc-float-card::before {
    content: '';
    position: absolute;
    inset: 10%;
    border: 1px solid rgba(255,255,255,0.06);
  }

  .v2-collaborate-{{ section.id }} .cc-float-card__eye {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--v2-gold);
    opacity: 0.84;
  }

  .v2-collaborate-{{ section.id }} .cc-float-card__eye svg {
    width: 7.6rem;
    height: 7.6rem;
  }

  .v2-collaborate-{{ section.id }} .cc-float-card__label {
    position: absolute;
    bottom: 1.1rem;
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-body-family);
    font-size: 0.74rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(255,255,255,0.34);
  }

  .v2-collaborate-{{ section.id }} .cc-ticker {
    background: var(--v2-surface);
    border-top: 1px solid var(--v2-border);
    border-bottom: 1px solid var(--v2-border);
    padding: 1.5rem 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .v2-collaborate-{{ section.id }} .cc-ticker__track {
    display: inline-flex;
    gap: 7.2rem;
    animation: cc-ticker-{{ section.id }} 30s linear infinite;
  }

  .v2-collaborate-{{ section.id }} .cc-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-body-family);
    font-size: 0.98rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    color: var(--v2-text-dim);
  }

  .v2-collaborate-{{ section.id }} .cc-ticker__item em {
    color: var(--v2-gold);
    font-style: normal;
  }

  .v2-collaborate-{{ section.id }} .cc-ticker__dot {
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: var(--v2-gold-dim);
  }

  .v2-collaborate-{{ section.id }} .cc-tabs {
    margin-top: 6rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tabs__buttons {
    display: flex;
    border: 1px solid var(--v2-border);
    margin-bottom: 0.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tab-button {
    flex: 1;
    min-height: 5.6rem;
    border: 0;
    border-right: 1px solid var(--v2-border);
    background: transparent;
    color: var(--v2-text-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .v2-collaborate-{{ section.id }} .cc-tab-button:last-child {
    border-right: 0;
  }

  .v2-collaborate-{{ section.id }} .cc-tab-button.is-active {
    color: var(--v2-gold);
    background: var(--v2-gold-faint);
    box-shadow: inset 0 -2px 0 0 var(--v2-gold);
  }

  .v2-collaborate-{{ section.id }} .cc-tab-panels {
    position: relative;
  }

  .v2-collaborate-{{ section.id }} .cc-tab-panel {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 0.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tab-panel.is-active {
    display: grid;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-card,
  .v2-collaborate-{{ section.id }} .cc-panel-visual {
    min-height: 100%;
    border: 1px solid var(--v2-border);
    background: var(--v2-surface);
    padding: 4.8rem 4.4rem;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-title {
    margin: 0 0 1.6rem;
    font-family: var(--font-heading-family);
    font-size: clamp(2.5rem, 2.7vw, 3.8rem);
    font-weight: 400;
    line-height: 1.12;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-title em {
    color: var(--v2-gold);
    font-style: italic;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-list li {
    display: flex;
    gap: 1.2rem;
    color: var(--v2-text-mid);
    font-size: 1.55rem;
    line-height: 1.7;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-list li::before {
    content: '—';
    color: var(--v2-gold);
    margin-top: 0.1rem;
    flex-shrink: 0;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-visual {
    background: var(--v2-surface-2);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(201,168,76,0.06), transparent 60%);
  }

  .v2-collaborate-{{ section.id }} .cc-panel-tag,
  .v2-collaborate-{{ section.id }} .cc-panel-label,
  .v2-collaborate-{{ section.id }} .cc-panel-example {
    position: relative;
    z-index: 1;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-tag,
  .v2-collaborate-{{ section.id }} .cc-panel-label,
  .v2-collaborate-{{ section.id }} .cc-process__num,
  .v2-collaborate-{{ section.id }} .cc-tier__name,
  .v2-collaborate-{{ section.id }} .cc-chart__title,
  .v2-collaborate-{{ section.id }} .cc-flow__num,
  .v2-collaborate-{{ section.id }} .cc-form__label,
  .v2-collaborate-{{ section.id }} .cc-faq__toggle-label {
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
    color: var(--v2-text-dim);
  }

  .v2-collaborate-{{ section.id }} .cc-panel-tag {
    color: var(--v2-gold-dim);
    margin-bottom: auto;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-metric {
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-big {
    font-family: var(--font-heading-family);
    font-size: clamp(4rem, 5vw, 7rem);
    line-height: 1;
    color: var(--v2-gold);
    margin-bottom: 0.6rem;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-example {
    margin-top: 2.4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--v2-border);
    font-size: 0.84rem;
    line-height: 1.8;
    color: var(--v2-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.14rem;
  }

  .v2-collaborate-{{ section.id }} .cc-panel-example strong {
    display: block;
    font-size: 1.08rem;
    letter-spacing: 0.04rem;
    color: var(--v2-gold-light);
    font-family: var(--font-heading-family);
    text-transform: none;
    margin-bottom: 0.5rem;
  }

  .v2-collaborate-{{ section.id }} .cc-steps {
    margin-top: 6rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.2rem;
    position: relative;
  }

  .v2-collaborate-{{ section.id }} .cc-steps::before {
    content: '';
    position: absolute;
    top: 4rem;
    left: 8%;
    right: 8%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--v2-border) 20%, var(--v2-border) 80%, transparent);
  }

  .v2-collaborate-{{ section.id }} .cc-step {
    text-align: center;
    padding: 0 1.2rem;
    position: relative;
    z-index: 1;
  }

  .v2-collaborate-{{ section.id }} .cc-step__circle {
    width: 8rem;
    height: 8rem;
    margin: 0 auto 2rem;
    border-radius: 50%;
    border: 1px solid var(--v2-border);
    display: grid;
    place-items: center;
    background: var(--v2-black);
    color: var(--v2-gold);
  }

  .v2-collaborate-{{ section.id }} .cc-step__title,
  .v2-collaborate-{{ section.id }} .cc-tier__title,
  .v2-collaborate-{{ section.id }} .cc-support__title,
  .v2-collaborate-{{ section.id }} .cc-example__title,
  .v2-collaborate-{{ section.id }} .cc-faq__question {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 400;
    color: var(--v2-text);
    line-height: 1.2;
  }

  .v2-collaborate-{{ section.id }} .cc-step__desc,
  .v2-collaborate-{{ section.id }} .cc-tier__desc,
  .v2-collaborate-{{ section.id }} .cc-support__list li,
  .v2-collaborate-{{ section.id }} .cc-example__desc,
  .v2-collaborate-{{ section.id }} .cc-faq__content,
  .v2-collaborate-{{ section.id }} .cc-form__input,
  .v2-collaborate-{{ section.id }} .cc-form__select,
  .v2-collaborate-{{ section.id }} .cc-note__text {
    color: var(--v2-text-dim);
    font-size: 1.48rem;
    line-height: 1.75;
  }

  .v2-collaborate-{{ section.id }} .cc-tiers,
  .v2-collaborate-{{ section.id }} .cc-handle,
  .v2-collaborate-{{ section.id }} .cc-examples,
  .v2-collaborate-{{ section.id }} .cc-revenue__scenarios,
  .v2-collaborate-{{ section.id }} .cc-upload-flow,
  .v2-collaborate-{{ section.id }} .cc-faq {
    margin-top: 6rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tiers,
  .v2-collaborate-{{ section.id }} .cc-handle,
  .v2-collaborate-{{ section.id }} .cc-examples,
  .v2-collaborate-{{ section.id }} .cc-upload-flow {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-upload-flow {
    grid-template-columns: repeat(4, 1fr);
  }

  .v2-collaborate-{{ section.id }} .cc-tier,
  .v2-collaborate-{{ section.id }} .cc-support,
  .v2-collaborate-{{ section.id }} .cc-example,
  .v2-collaborate-{{ section.id }} .cc-flow,
  .v2-collaborate-{{ section.id }} .cc-scenario,
  .v2-collaborate-{{ section.id }} .cc-chart,
  .v2-collaborate-{{ section.id }} .cc-note,
  .v2-collaborate-{{ section.id }} .cc-form {
    border: 1px solid var(--v2-border);
    background: var(--v2-surface);
  }

  .v2-collaborate-{{ section.id }} .cc-tier {
    position: relative;
    overflow: hidden;
  }

  .v2-collaborate-{{ section.id }} .cc-tier--featured {
    background: linear-gradient(135deg, var(--v2-surface) 0%, rgba(201,168,76,0.04) 100%);
    border-color: rgba(201,168,76,0.35);
  }

  .v2-collaborate-{{ section.id }} .cc-tier--featured::before {
    content: 'Most Popular';
    position: absolute;
    top: 0;
    right: 0;
    background: var(--v2-gold);
    color: #080808;
    font-family: var(--font-body-family);
    font-size: 0.76rem;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    padding: 0.7rem 1.4rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tier__header {
    padding: 3.6rem 3.6rem 2.8rem;
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-collaborate-{{ section.id }} .cc-tier__editions {
    font-family: var(--font-heading-family);
    font-size: clamp(4.4rem, 5vw, 6.8rem);
    line-height: 1;
    color: var(--v2-text);
    margin-bottom: 0.4rem;
  }

  .v2-collaborate-{{ section.id }} .cc-tier__body,
  .v2-collaborate-{{ section.id }} .cc-support,
  .v2-collaborate-{{ section.id }} .cc-example,
  .v2-collaborate-{{ section.id }} .cc-flow,
  .v2-collaborate-{{ section.id }} .cc-scenario,
  .v2-collaborate-{{ section.id }} .cc-chart,
  .v2-collaborate-{{ section.id }} .cc-note,
  .v2-collaborate-{{ section.id }} .cc-form {
    padding: 3.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-mini-list,
  .v2-collaborate-{{ section.id }} .cc-support__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .v2-collaborate-{{ section.id }} .cc-mini-list li,
  .v2-collaborate-{{ section.id }} .cc-support__list li {
    display: flex;
    gap: 1rem;
  }

  .v2-collaborate-{{ section.id }} .cc-mini-list li::before,
  .v2-collaborate-{{ section.id }} .cc-support__list li::before {
    content: '·';
    color: var(--v2-gold);
    font-size: 1.8rem;
    line-height: 1;
    margin-top: -0.1rem;
    flex-shrink: 0;
  }

  .v2-collaborate-{{ section.id }} .cc-earnings {
    margin: 2.4rem 0;
    padding: 1.6rem 2rem;
    border: 1px solid var(--v2-border);
    background: rgba(201,168,76,0.06);
  }

  .v2-collaborate-{{ section.id }} .cc-earnings__value,
  .v2-collaborate-{{ section.id }} .cc-scenario__earn,
  .v2-collaborate-{{ section.id }} .cc-example__earn {
    font-family: var(--font-heading-family);
    color: var(--v2-gold);
    font-size: 2.5rem;
  }

  .v2-collaborate-{{ section.id }} .cc-revenue {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: center;
  }

  .v2-collaborate-{{ section.id }} .cc-chart__bars {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-top: 3rem;
  }

  .v2-collaborate-{{ section.id }} .cc-chart__row {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }

  .v2-collaborate-{{ section.id }} .cc-chart__track {
    position: relative;
    flex: 1;
    height: 2.8rem;
    background: rgba(255,255,255,0.04);
    overflow: hidden;
  }

  .v2-collaborate-{{ section.id }} .cc-chart__fill {
    height: 100%;
    display: flex;
    align-items: center;
    padding-left: 1.2rem;
    color: #080808;
    font-family: var(--font-body-family);
    font-size: 0.86rem;
    letter-spacing: 0.12rem;
    text-transform: uppercase;
  }

  .v2-collaborate-{{ section.id }} .cc-chart__fill--you {
    width: 65%;
    background: linear-gradient(to right, var(--v2-gold-dim), var(--v2-gold));
  }

  .v2-collaborate-{{ section.id }} .cc-chart__fill--iris {
    width: 35%;
    background: rgba(255,255,255,0.08);
    color: var(--v2-text-dim);
  }

  .v2-collaborate-{{ section.id }} .cc-note {
    display: flex;
    gap: 1.4rem;
    align-items: flex-start;
    border-left: 2px solid var(--v2-gold);
  }

  .v2-collaborate-{{ section.id }} .cc-note__icon,
  .v2-collaborate-{{ section.id }} .cc-support__icon,
  .v2-collaborate-{{ section.id }} .cc-flow__icon,
  .v2-collaborate-{{ section.id }} .cc-step__circle svg {
    color: var(--v2-gold);
  }

  .v2-collaborate-{{ section.id }} .cc-faq {
    border-top: 1px solid var(--v2-border);
  }

  .v2-collaborate-{{ section.id }} .cc-faq__item {
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-collaborate-{{ section.id }} .cc-faq__toggle {
    width: 100%;
    padding: 2rem 0;
    border: 0;
    background: transparent;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    cursor: pointer;
    text-align: left;
  }

  .v2-collaborate-{{ section.id }} .cc-faq__plus {
    color: var(--v2-gold);
    font-size: 2.4rem;
    line-height: 1;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .v2-collaborate-{{ section.id }} .cc-faq__item.is-open .cc-faq__plus {
    transform: rotate(45deg);
  }

  .v2-collaborate-{{ section.id }} .cc-faq__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .v2-collaborate-{{ section.id }} .cc-faq__body-inner {
    padding: 0 0 2.2rem;
  }

  .v2-collaborate-{{ section.id }} .cc-cta-final {
    text-align: center;
    position: relative;
  }

  .v2-collaborate-{{ section.id }} .cc-cta-final::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80rem;
    height: 80rem;
    background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .v2-collaborate-{{ section.id }} .cc-cta-final > * {
    position: relative;
    z-index: 1;
  }

  .v2-collaborate-{{ section.id }} .cc-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
    margin-top: 4.8rem;
  }

  .v2-collaborate-{{ section.id }} .cc-form-field {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .v2-collaborate-{{ section.id }} .cc-form-field--full {
    grid-column: 1 / -1;
  }

  .v2-collaborate-{{ section.id }} .cc-form__input,
  .v2-collaborate-{{ section.id }} .cc-form__select {
    width: 100%;
    padding: 1.4rem 1.8rem;
    border: 1px solid var(--v2-border);
    background: rgba(255,255,255,0.03);
    color: var(--v2-text);
    outline: none;
    font-family: var(--font-body-family);
  }

  .v2-collaborate-{{ section.id }} .cc-form__select {
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .v2-collaborate-{{ section.id }} textarea.cc-form__input {
    min-height: 14rem;
    resize: vertical;
  }

  .v2-collaborate-{{ section.id }} .cc-form__input::placeholder {
    color: var(--v2-text-dim);
  }

  .v2-collaborate-{{ section.id }} .cc-form__submit {
    margin-top: 0.2rem;
    grid-column: 1 / -1;
  }

  .v2-collaborate-{{ section.id }} .cc-form__errors,
  .v2-collaborate-{{ section.id }} .cc-form__success {
    margin-top: 1.6rem;
    color: var(--v2-text-mid);
    font-size: 1.4rem;
  }

  @keyframes cc-ticker-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media screen and (max-width: 1200px) {
    .v2-collaborate-{{ section.id }} .cc-hero__left,
    .v2-collaborate-{{ section.id }} .cc-hero__right,
    .v2-collaborate-{{ section.id }} .cc-section {
      padding-left: 4rem;
      padding-right: 4rem;
    }

