{%- style -%}
  .v2-archive-preview-{{ section.id }} {
    --v2-gold: #c9a84c;
    --v2-gold-dim: #7a6330;
    --v2-surface: #101010;
    --v2-surface-2: #171717;
    --v2-border: rgba(201, 168, 76, 0.15);
    --v2-text: #ede8df;
    --v2-text-mid: #a89f90;
    background: var(--v2-surface);
    color: var(--v2-text);
    border-top: 1px solid var(--v2-border);
  }

  .v2-archive-preview__wrap-{{ section.id }} {
    max-width: 136rem;
    margin: 0 auto;
    padding: 12rem 8rem;
  }

  .v2-archive-preview__head-{{ section.id }} {
    text-align: center;
    margin-bottom: 6.4rem;
  }

  .v2-archive-preview__eyebrow-{{ section.id }} {
    margin: 0 0 1.6rem;
    color: var(--v2-gold-dim);
    text-transform: uppercase;
    letter-spacing: 0.42rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
  }

  .v2-archive-preview__title-{{ section.id }} {
    margin: 0 0 2rem;
    font-family: var(--font-heading-family);
    font-size: clamp(3.4rem, 4.4vw, 5.8rem);
    line-height: 1.08;
    letter-spacing: 0.03em;
    font-weight: 400;
    color: var(--v2-text) !important;
  }

  .v2-archive-preview__title-{{ section.id }},
  .v2-archive-preview__title-{{ section.id }} * {
    color: var(--v2-text) !important;
  }

  .v2-archive-preview__title-{{ section.id }} em,
  .v2-archive-preview__title-{{ section.id }} em * {
    color: var(--v2-gold) !important;
    font-style: italic;
    font-weight: 400;
  }

  .v2-archive-preview__description-{{ section.id }} {
    max-width: 68rem;
    margin: 0 auto;
    color: var(--v2-text-mid);
    font-size: 1.75rem;
    line-height: 1.8;
  }

  .v2-archive-preview__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.4rem;
    min-height: 18rem;
  }

  .v2-archive-preview__card-{{ section.id }} {
    position: relative;
    display: block;
    background: var(--v2-surface-2);
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--v2-border);
  }

  .v2-archive-preview__card-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.45s ease;
    background: #2a2a2a;
  }

  .v2-archive-preview__card-{{ section.id }}:hover img {
    transform: scale(1.04);
  }

  .v2-archive-preview__placeholder-{{ section.id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, rgba(201, 168, 76, 0.12), rgba(255,255,255,0.03));
  }

  .v2-archive-preview__overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: end;
    background: linear-gradient(180deg, rgba(8,8,8,0.05) 25%, rgba(8,8,8,0.78) 100%);
    padding: 2rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .v2-archive-preview__card-{{ section.id }}:hover .v2-archive-preview__overlay-{{ section.id }} {
    opacity: 1;
  }

  .v2-archive-preview__label-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .v2-archive-preview__iris-{{ section.id }} {
    color: var(--v2-text);
    font-family: var(--font-heading-family);
    font-size: 2rem;
    line-height: 1.1;
  }

  .v2-archive-preview__meta-{{ section.id }} {
    color: var(--v2-gold);
    text-transform: uppercase;
    letter-spacing: 0.18rem;
    font-size: 0.95rem;
    font-family: var(--font-body-family);
  }

  .v2-archive-preview__cta-{{ section.id }} {
    margin-top: 5rem;
    text-align: center;
  }

  .v2-archive-preview__button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.6rem;
    padding: 1.6rem 3rem;
    border: 1px solid var(--v2-border);
    color: var(--v2-gold);
    background: rgba(201, 168, 76, 0.04);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.24rem;
    font-size: 1.1rem;
    font-family: var(--font-body-family);
    transition: all 0.25s ease;
  }

  .v2-archive-preview__button-{{ section.id }}:hover {
    border-color: rgba(201, 168, 76, 0.5);
    background: rgba(201, 168, 76, 0.08);
  }

  .v2-archive-preview__empty-{{ section.id }} {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 16rem;
    border: 1px solid var(--v2-border);
    color: var(--v2-text-mid);
    font-size: 1.5rem;
    letter-spacing: 0.08rem;
  }

  @media screen and (max-width: 989px) {
    .v2-archive-preview__wrap-{{ section.id }} {
      padding: 9rem 3.2rem;
    }

    .v2-archive-preview__grid-{{ section.id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .v2-archive-preview__wrap-{{ section.id }} {
      padding: 7rem 2rem;
    }

    .v2-archive-preview__eyebrow-{{ section.id }} {
      letter-spacing: 0.28rem;
      font-size: 0.9rem;
    }

    .v2-archive-preview__description-{{ section.id }} {
      font-size: 1.6rem;
      line-height: 1.75;
    }

    .v2-archive-preview__grid-{{ section.id }} {
      gap: 0.3rem;
    }

    .v2-archive-preview__overlay-{{ section.id }} {
      padding: 1.5rem;
    }

    .v2-archive-preview__iris-{{ section.id }} {
      font-size: 1.7rem;
    }

    .v2-archive-preview__meta-{{ section.id }} {
      font-size: 0.85rem;
      letter-spacing: 0.14rem;
    }

    .v2-archive-preview__button-{{ section.id }} {
      width: 100%;
    }
  }
{%- endstyle -%}

<section class="v2-archive-preview-{{ section.id }}" id="V2ArchivePreview-{{ section.id }}">
  <div class="v2-archive-preview__wrap-{{ section.id }}">
    <div class="v2-archive-preview__head-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="v2-archive-preview__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="v2-archive-preview__title-{{ section.id }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="v2-archive-preview__description-{{ section.id }}">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="v2-archive-preview__grid-{{ section.id }}" id="V2ArchivePreviewGrid-{{ section.id }}">
      <div class="v2-archive-preview__empty-{{ section.id }}">Loading revealed works…</div>
    </div>

    <div class="v2-archive-preview__cta-{{ section.id }}">
      <a
        class="v2-archive-preview__button-{{ section.id }}"
        href="{{ section.settings.button_link | default: '/pages/iris-archive' }}"
      >
        {{ section.settings.button_label | escape }}
      </a>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('V2ArchivePreview-{{ section.id }}');
    var grid = document.getElementById('V2ArchivePreviewGrid-{{ section.id }}');
    if (!root || !grid) return;

    function render(items) {
      if (!items.length) {
        grid.innerHTML = '<div class="v2-archive-preview__empty-{{ section.id }}">No revealed IRIS available right now.</div>';
        return;
      }

      grid.innerHTML = items.map(function (item) {
        var href = '/pages/iris-passport?iris_id=' + encodeURIComponent(item.iris_id);
        var img = item.image_url
          ? '<img src="' + item.image_url + '" alt="' + item.iris_id + '" loading="lazy">'
          : '<div class="v2-archive-preview__placeholder-{{ section.id }}"></div>';

        return (
          '<a class="v2-archive-preview__card-{{ section.id }}" href="' + href + '">' +
            img +
            '<div class="v2-archive-preview__overlay-{{ section.id }}">' +
              '<div class="v2-archive-preview__label-{{ section.id }}">' +
                '<div class="v2-archive-preview__iris-{{ section.id }}">' + item.iris_id + '</div>' +
                '<div class="v2-archive-preview__meta-{{ section.id }}">' + (item.rarity_code || 'Rarity hidden') + '</div>' +
              '</div>' +
            '</div>' +
          '</a>'
        );
      }).join('');
    }

    fetch('/apps/iris/seen-archive?limit={{ section.settings.items_to_show }}', {
      headers: { Accept: 'application/json' },
      cache: 'no-store'
    })
      .then(function (response) {
        if (!response.ok) throw new Error('bad_status');
        return response.json();
      })
      .then(function (data) {
        render((data && data.items) ? data.items : []);
      })
      .catch(function () {
        grid.innerHTML = '<div class="v2-archive-preview__empty-{{ section.id }}">Could not load the archive preview.</div>';
      });
  })();
</script>

{% schema %}
{
  "name": "V2 Archive Preview",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Revealed Archive"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "What others have <em>received</em>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Every activated IRIS enters the visible history of the edition. Browse the works that have already been claimed and revealed.</p>"
    },
    {
      "type": "range",
      "id": "items_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Items to show",
      "default": 8
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore the Archive"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "V2 Archive Preview"
    }
  ]
}
{% endschema %}
