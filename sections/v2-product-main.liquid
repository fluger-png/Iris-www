{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_price = current_variant.price | default: product.price
  assign product_price_display = product_price | money_without_trailing_zeros
  assign display_media = section.settings.display_image
  assign art_image_class = 'v2-product-main__art-image-' | append: section.id
  assign product_form_installment_id = 'v2-product-installment-' | append: section.id
  if display_media == blank
    assign display_media = product.featured_media
  endif
-%}

{%- style -%}
  .v2-product-main-{{ section.id }} {
    --v2-product-gold: #c9a84c;
    --v2-product-gold-dim: #7a6330;
    --v2-product-border: rgba(201, 168, 76, 0.16);
    --v2-product-text: #ede8df;
    --v2-product-text-mid: #a89f90;
    --v2-product-text-soft: rgba(237, 232, 223, 0.62);
    --v2-product-surface: #101010;
    --v2-product-surface-2: #171717;
    background: #000;
    color: var(--v2-product-text);
    border-top: 1px solid var(--v2-product-border);
  }

  .v2-product-main__wrap-{{ section.id }} {
    max-width: 144rem;
    margin: 0 auto;
    padding: 9.6rem 4rem 8rem;
  }

  .v2-product-main__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 0.88fr);
    gap: 8rem;
    align-items: start;
  }

  .v2-product-main__visual-shell-{{ section.id }} {
    position: sticky;
    top: 11rem;
  }

  .v2-product-main__art-{{ section.id }} {
    position: relative;
    background: transparent;
    border: 0;
    padding: 0;
    aspect-ratio: 1 / 1;
  }

  .v2-product-main__art-inner-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-product-main__art-badge-{{ section.id }},
  .v2-product-main__art-badge-bottom-{{ section.id }} {
    position: absolute;
    z-index: 2;
    min-height: 4.6rem;
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: rgba(12, 12, 12, 0.92);
    border: 1px solid var(--v2-product-border);
    color: var(--v2-product-gold);
    text-transform: uppercase;
    letter-spacing: 0.26rem;
    font-size: 1rem;
    white-space: nowrap;
  }

  .v2-product-main__art-badge-{{ section.id }} {
    top: 4rem;
    left: 3rem;
  }

  .v2-product-main__art-badge-bottom-{{ section.id }} {
    right: 3rem;
    bottom: 3rem;
    color: var(--v2-product-text-mid);
  }

  .v2-product-main__art-image-{{ section.id }} {
    width: 75%;
    height: 75%;
    object-fit: contain;
    display: block;
  }

  .v2-product-main__art-placeholder-{{ section.id }} {
    width: 76%;
    height: 76%;
    background: #0d0d0d;
  }

  .v2-product-main__eyebrow-{{ section.id }} {
    margin: 0 0 2rem;
    color: var(--v2-product-gold-dim);
    text-transform: uppercase;
    letter-spacing: 0.42rem;
    font-size: 1.05rem;
  }

  .v2-product-main__title-{{ section.id }} {
    margin: 0;
    color: var(--v2-product-text);
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 3.2vw, 3.8rem);
    line-height: 1.02;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .v2-product-main__title-{{ section.id }} em {
    color: var(--v2-product-gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-product-main__subtitle-{{ section.id }} {
    margin: 2.2rem 0 0;
    color: var(--v2-product-text-mid);
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: clamp(1.65rem, 1.98vw, 2.2rem);
    line-height: 1.35;
  }

  .v2-product-main__divider-{{ section.id }} {
    width: 6rem;
    height: 1px;
    background: var(--v2-product-gold);
    margin: 4rem 0 4.2rem;
  }

  .v2-product-main__description-{{ section.id }} {
    color: var(--v2-product-text-mid);
    font-size: 1.5rem;
    line-height: 1.8;
    max-width: 66rem;
  }

  .v2-product-main__description-{{ section.id }} p {
    margin: 0 0 1.8rem;
  }

  .v2-product-main__callout-{{ section.id }} {
    margin-top: 3.8rem;
    padding: 2.7rem 3rem;
    border: 1px solid var(--v2-product-border);
    border-left: 3px solid var(--v2-product-gold);
    background: rgba(201, 168, 76, 0.02);
  }

  .v2-product-main__callout-title-{{ section.id }} {
    margin: 0 0 1.1rem;
    color: var(--v2-product-text);
    text-transform: uppercase;
    letter-spacing: 0.28rem;
    font-size: 0.88rem;
  }

  .v2-product-main__callout-copy-{{ section.id }} {
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.18rem;
    font-size: 0.85rem;
    line-height: 1.75;
  }

  .v2-product-main__progress-{{ section.id }} {
    margin-top: 4rem;
  }

  .v2-product-main__progress-row-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    margin-bottom: 1.4rem;
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.28rem;
    font-size: 0.88rem;
  }

  .v2-product-main__progress-row-{{ section.id }} strong {
    color: var(--v2-product-gold);
    font-weight: 400;
  }

  .v2-product-main__progress-bar-{{ section.id }} {
    position: relative;
    height: 4px;
    background: #1D1C1B;
    overflow: hidden;
  }

  .v2-product-main__progress-fill-{{ section.id }} {
    position: absolute;
    left: 0;
    top: 0;
    height: 4px;
    width: 0;
    background: var(--v2-product-gold);
  }

  .v2-product-main__price-card-{{ section.id }} {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 2rem 3rem;
    margin-top: 4rem;
    padding: 3.2rem 3rem 2.8rem;
    border: 1px solid var(--v2-product-border);
    background: rgba(255, 255, 255, 0.01);
  }

  .v2-product-main__price-value-{{ section.id }} {
    margin: 0;
    color: var(--v2-product-text);
    font-family: var(--font-heading-family);
    font-size: clamp(4.1rem, 5.17vw, 5.85rem);
    line-height: 0.92;
    font-weight: 400;
  }

  .v2-product-main__price-label-{{ section.id }} {
    margin-top: 1rem;
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.26rem;
    font-size: 0.81rem;
  }

  .v2-product-main__price-side-{{ section.id }} {
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.18rem;
    font-size: 0.81rem;
    line-height: 1.8;
    text-align: right;
  }

  .v2-product-main__quantity-row-{{ section.id }} {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .v2-product-main__quantity-control-{{ section.id }} {
    display: inline-grid;
    grid-template-columns: 5.2rem 10rem 5.2rem;
    align-items: stretch;
    border: 1px solid var(--v2-product-border);
    background: rgba(255, 255, 255, 0.02);
  }

  .v2-product-main__quantity-button-{{ section.id }} {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--v2-product-text);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .v2-product-main__quantity-button-{{ section.id }}:hover {
    background: rgba(201, 168, 76, 0.08);
    color: var(--v2-product-gold);
  }

  .v2-product-main__quantity-label-{{ section.id }} {
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.24rem;
    font-size: 0.84rem;
    white-space: nowrap;
  }

  .v2-product-main__quantity-input-{{ section.id }} {
    min-height: 5.2rem;
    width: 100%;
    padding: 0 1rem;
    border: 0;
    border-left: 1px solid var(--v2-product-border);
    border-right: 1px solid var(--v2-product-border);
    background: transparent;
    color: var(--v2-product-text);
    font-size: 1.58rem;
    text-align: center;
  }

  .v2-product-main__quantity-input-{{ section.id }}::-webkit-outer-spin-button,
  .v2-product-main__quantity-input-{{ section.id }}::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .v2-product-main__installments-{{ section.id }} {
    margin-top: 1.6rem;
    color: var(--v2-product-text-soft);
    font-size: 1.19rem;
    line-height: 1.7;
  }

  .v2-product-main__installments-{{ section.id }} a {
    color: var(--v2-product-text);
  }

  .v2-product-main__feature-list-{{ section.id }} {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 1.8rem 3rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .v2-product-main__feature-item-{{ section.id }} {
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.18rem;
    font-size: 0.81rem;
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .v2-product-main__feature-item-{{ section.id }}::before {
    content: '';
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--v2-product-gold);
    flex: 0 0 auto;
  }

  .v2-product-main__actions-{{ section.id }} {
    margin-top: 3rem;
    display: grid;
    gap: 1.4rem;
  }

  .v2-product-main__button-{{ section.id }},
  .v2-product-main__button-secondary-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 7.2rem;
    width: 100%;
    border: 1px solid var(--v2-product-border);
    text-transform: uppercase;
    letter-spacing: 0.34rem;
    font-size: 1.06rem;
    text-decoration: none;
    transition: all 0.24s ease;
  }

  .v2-product-main__button-{{ section.id }} {
    background: var(--v2-product-gold);
    color: #0f0f0f;
    border-color: transparent;
    cursor: pointer;
  }

  .v2-product-main__button-{{ section.id }}:hover {
    background: #d3b35b;
  }

  .v2-product-main__button-{{ section.id }}[disabled] {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .v2-product-main__button-secondary-{{ section.id }} {
    background: transparent;
    color: var(--v2-product-gold);
  }

  .v2-product-main__button-secondary-{{ section.id }}:hover {
    background: rgba(201, 168, 76, 0.06);
    border-color: rgba(201, 168, 76, 0.42);
  }

  .v2-product-main__error-{{ section.id }} {
    margin: 0;
    color: #de7b7b;
    font-size: 1.4rem;
    line-height: 1.6;
  }

  .v2-product-main__error-{{ section.id }}[hidden] {
    display: none;
  }

  .v2-product-main__details-stack-{{ section.id }} {
    margin-top: 3rem;
  }

  .v2-product-main__facts-{{ section.id }} {
    border: 1px solid var(--v2-product-border);
    background: #0d0d0d;
  }

  .v2-product-main__fact-{{ section.id }} {
    display: grid;
    grid-template-columns: 7.6rem minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
    padding: 2.2rem 2.6rem;
    border-bottom: 1px solid var(--v2-product-border);
  }

  .v2-product-main__fact-{{ section.id }}:last-child {
    border-bottom: 0;
  }

  .v2-product-main__fact-icon-{{ section.id }} {
    width: 5.8rem;
    height: 5.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--v2-product-border);
    color: var(--v2-product-gold);
  }

  .v2-product-main__fact-icon-{{ section.id }} svg {
    width: 2.3rem;
    height: 2.3rem;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .v2-product-main__fact-title-{{ section.id }} {
    margin: 0 0 0.6rem;
    color: var(--v2-product-text);
    font-family: var(--font-heading-family);
    font-size: clamp(1.6rem, 1.8vw, 2.3rem);
    line-height: 1.1;
    font-weight: 400;
  }

  .v2-product-main__fact-meta-{{ section.id }} {
    color: var(--v2-product-text-mid);
    text-transform: uppercase;
    letter-spacing: 0.22rem;
    font-size: 0.79rem;
    line-height: 1.6;
  }

  .v2-product-main__faq-{{ section.id }} {
    margin-top: 3rem;
    border-top: 1px solid var(--v2-product-border);
  }

  .v2-product-main__faq-item-{{ section.id }} {
    border-bottom: 1px solid var(--v2-product-border);
  }

  .v2-product-main__faq-item-{{ section.id }} summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding: 2.8rem 0;
  }

  .v2-product-main__faq-item-{{ section.id }} summary::-webkit-details-marker {
    display: none;
  }

  .v2-product-main__faq-question-{{ section.id }} {
    color: var(--v2-product-text);
    font-family: var(--font-heading-family);
    font-size: clamp(1.6rem, 1.95vw, 2.4rem);
    line-height: 1.12;
    font-weight: 400;
  }

  .v2-product-main__faq-toggle-{{ section.id }} {
    position: relative;
    width: 2.8rem;
    height: 2.8rem;
    flex: 0 0 auto;
  }

  .v2-product-main__faq-toggle-{{ section.id }}::before,
  .v2-product-main__faq-toggle-{{ section.id }}::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 2rem;
    height: 1.5px;
    background: var(--v2-product-gold);
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease;
  }

  .v2-product-main__faq-toggle-{{ section.id }}::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .v2-product-main__faq-item-{{ section.id }}[open] .v2-product-main__faq-toggle-{{ section.id }}::after {
    opacity: 0;
  }

  .v2-product-main__faq-answer-{{ section.id }} {
    padding: 0 0 2.6rem;
    color: var(--v2-product-text-mid);
    font-size: 1.32rem;
    line-height: 1.8;
  }

  .v2-product-main__faq-answer-{{ section.id }} p {
    margin: 0;
  }

  @media screen and (max-width: 1199px) {
    .v2-product-main__grid-{{ section.id }} {
      gap: 5rem;
    }
  }

  @media screen and (max-width: 989px) {
    .v2-product-main__wrap-{{ section.id }} {
      padding: 8rem 3.2rem 7rem;
    }

    .v2-product-main__grid-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 4.4rem;
    }

    .v2-product-main__visual-shell-{{ section.id }} {
      position: static;
    }

    .v2-product-main__price-card-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .v2-product-main__price-side-{{ section.id }} {
      text-align: left;
    }

    .v2-product-main__fact-{{ section.id }} {
      grid-template-columns: 6.4rem minmax(0, 1fr);
      gap: 1.6rem;
      padding: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .v2-product-main__wrap-{{ section.id }} {
      padding: 6.5rem 2rem 6rem;
    }

    .v2-product-main__eyebrow-{{ section.id }} {
      letter-spacing: 0.28rem;
      font-size: 0.95rem;
    }

    .v2-product-main__subtitle-{{ section.id }} {
      font-size: 1.8rem;
    }

    .v2-product-main__description-{{ section.id }} {
      font-size: 1.65rem;
      line-height: 1.78;
    }

    .v2-product-main__art-badge-{{ section.id }},
    .v2-product-main__art-badge-bottom-{{ section.id }} {
      min-height: 4rem;
      padding: 0.8rem 1.4rem;
      letter-spacing: 0.18rem;
      font-size: 0.85rem;
    }

    .v2-product-main__art-badge-{{ section.id }} {
      top: 1.6rem;
      left: 1.6rem;
    }

    .v2-product-main__art-badge-bottom-{{ section.id }} {
      right: 1.6rem;
      bottom: 1.6rem;
    }

    .v2-product-main__callout-{{ section.id }},
    .v2-product-main__price-card-{{ section.id }} {
      padding-inline: 2rem;
    }

    .v2-product-main__feature-list-{{ section.id }} {
      gap: 1.4rem 1.8rem;
    }

    .v2-product-main__button-{{ section.id }},
    .v2-product-main__button-secondary-{{ section.id }} {
      min-height: 6.4rem;
      letter-spacing: 0.24rem;
      font-size: 1.14rem;
    }

    .v2-product-main__quantity-row-{{ section.id }} {
      align-items: stretch;
    }

    .v2-product-main__quantity-input-{{ section.id }} {
      font-size: 1.45rem;
    }

    .v2-product-main__quantity-control-{{ section.id }} {
      grid-template-columns: 4.8rem 8.8rem 4.8rem;
    }

    .v2-product-main__fact-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .v2-product-main__fact-icon-{{ section.id }} {
      width: 5.2rem;
      height: 5.2rem;
    }

    .v2-product-main__faq-question-{{ section.id }} {
      font-size: 1.85rem;
    }

    .v2-product-main__faq-answer-{{ section.id }} {
      font-size: 1.5rem;
    }
  }
{%- endstyle -%}

{% capture v2_fact_icon_1 %}
  <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="4" width="12" height="16" rx="1"></rect><line x1="9" y1="8" x2="15" y2="8"></line><line x1="9" y1="12" x2="15" y2="12"></line><line x1="9" y1="16" x2="13" y2="16"></line></svg>
{% endcapture %}
{% capture v2_fact_icon_2 %}
  <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"></circle><path d="M12 7v5l3 2"></path></svg>
{% endcapture %}
{% capture v2_fact_icon_3 %}
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-3z"></path></svg>
{% endcapture %}
{% capture v2_fact_icon_4 %}
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s6-4.35 6-10a6 6 0 10-12 0c0 5.65 6 10 6 10z"></path><circle cx="12" cy="11" r="2.5"></circle></svg>
{% endcapture %}

<section class="v2-product-main-{{ section.id }}">
  <div class="v2-product-main__wrap-{{ section.id }}">
    <div class="v2-product-main__grid-{{ section.id }}">
      <div class="v2-product-main__visual-shell-{{ section.id }}">
        <div class="v2-product-main__art-{{ section.id }}">
          <div class="v2-product-main__art-inner-{{ section.id }}">
            {%- if display_media != blank -%}
              {{
                display_media
                | image_url: width: 1600
                | image_tag:
                  class: art_image_class,
                  loading: 'lazy',
                  alt: product.title
              }}
            {%- else -%}
              <div class="v2-product-main__art-placeholder-{{ section.id }}"></div>
            {%- endif -%}
          </div>

        </div>
      </div>

      <div>
        {%- assign product_vendor_display = product.vendor | default: 'IRIS NYC' -%}
        <p class="v2-product-main__eyebrow-{{ section.id }}">{{ product_vendor_display }} · Physical Collectible Art</p>

        <h1 class="v2-product-main__title-{{ section.id }}">{{ product.title }}</h1>

        {%- if section.settings.subtitle != blank -%}
          <p class="v2-product-main__subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <div class="v2-product-main__divider-{{ section.id }}"></div>

        {%- if product.description != blank -%}
          <div class="v2-product-main__description-{{ section.id }}">{{ product.description }}</div>
        {%- elsif section.settings.description != blank -%}
          <div class="v2-product-main__description-{{ section.id }}">{{ section.settings.description }}</div>
        {%- endif -%}

        <div class="v2-product-main__callout-{{ section.id }}">
          {%- if section.settings.callout_title != blank -%}
            <p class="v2-product-main__callout-title-{{ section.id }}">{{ section.settings.callout_title }}</p>
          {%- endif -%}
          {%- if section.settings.callout_text != blank -%}
            <div class="v2-product-main__callout-copy-{{ section.id }}" id="V2ProductCalloutCopy-{{ section.id }}">{{ section.settings.callout_text }}</div>
          {%- endif -%}
        </div>

        <div class="v2-product-main__progress-{{ section.id }}">
          <div class="v2-product-main__progress-row-{{ section.id }}">
            <span>{{ section.settings.progress_label }}</span>
            <strong id="V2ProductRevealCount-{{ section.id }}">—</strong>
          </div>
          <div class="v2-product-main__progress-bar-{{ section.id }}" id="V2ProductRevealBar-{{ section.id }}">
            <div class="v2-product-main__progress-fill-{{ section.id }}" id="V2ProductRevealFill-{{ section.id }}"></div>
          </div>
        </div>

        <div class="v2-product-main__price-card-{{ section.id }}">
          <div>
            <p class="v2-product-main__price-value-{{ section.id }}">{{ product_price_display }}</p>
            <div class="v2-product-main__price-label-{{ section.id }}">{{ section.settings.price_caption }}</div>
          </div>

          <div class="v2-product-main__price-side-{{ section.id }}">
            {%- if section.settings.shipping_line_1 != blank -%}<div>{{ section.settings.shipping_line_1 }}</div>{%- endif -%}
            {%- if section.settings.shipping_line_2 != blank -%}<div>{{ section.settings.shipping_line_2 }}</div>{%- endif -%}
            {%- if section.settings.shipping_line_3 != blank -%}<div>{{ section.settings.shipping_line_3 }}</div>{%- endif -%}
          </div>

          <ul class="v2-product-main__feature-list-{{ section.id }}">
            {%- for index in (1..4) -%}
              {%- assign feature_key = 'feature_' | append: index -%}
              {%- assign feature_value = section.settings[feature_key] -%}
              {%- if feature_value != blank -%}
                <li class="v2-product-main__feature-item-{{ section.id }}">{{ feature_value }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

        <div class="v2-product-main__quantity-row-{{ section.id }}">
          <label class="v2-product-main__quantity-label-{{ section.id }}" for="V2ProductQuantity-{{ section.id }}">Quantity</label>
          <div class="v2-product-main__quantity-control-{{ section.id }}">
            <button
              type="button"
              class="v2-product-main__quantity-button-{{ section.id }}"
              data-quantity-minus
              aria-label="Decrease quantity"
            >
              −
            </button>
            <input
              id="V2ProductQuantity-{{ section.id }}"
              class="v2-product-main__quantity-input-{{ section.id }}"
              type="number"
              min="1"
              max="10"
              step="1"
              value="1"
              inputmode="numeric"
            >
            <button
              type="button"
              class="v2-product-main__quantity-button-{{ section.id }}"
              data-quantity-plus
              aria-label="Increase quantity"
            >
              +
            </button>
          </div>
        </div>

        <div class="v2-product-main__installments-{{ section.id }}">
          {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {{ form | payment_terms }}
          {%- endform -%}
        </div>

        <div class="v2-product-main__actions-{{ section.id }}">
          <button
            type="button"
            class="v2-product-main__button-{{ section.id }}"
            data-iris-buy-button
            data-variant-id="{{ current_variant.id }}"
            data-product-id="{{ product.id }}"
            data-product-handle="{{ product.handle }}"
            {% unless current_variant and current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant and current_variant.available -%}
              {{ section.settings.primary_button_label }} — {{ product_price_display }}
            {%- else -%}
              Sold out
            {%- endif -%}
          </button>

          <a
            class="v2-product-main__button-secondary-{{ section.id }}"
            href="{{ section.settings.archive_link | default: '/pages/iris-archive' }}"
          >
            {{ section.settings.archive_button_label }}
          </a>

          <p class="v2-product-main__error-{{ section.id }}" id="V2ProductError-{{ section.id }}" hidden></p>
        </div>

        <div class="v2-product-main__details-stack-{{ section.id }}">
          <div class="v2-product-main__facts-{{ section.id }}">
            {%- for index in (1..4) -%}
              {%- assign title_key = 'fact_title_' | append: index -%}
              {%- assign meta_key = 'fact_meta_' | append: index -%}
              {%- assign title_value = section.settings[title_key] -%}
              {%- assign meta_value = section.settings[meta_key] -%}
              <div class="v2-product-main__fact-{{ section.id }}">
                <div class="v2-product-main__fact-icon-{{ section.id }}">
                  {%- case index -%}
                    {%- when 1 -%}{{ v2_fact_icon_1 }}
                    {%- when 2 -%}{{ v2_fact_icon_2 }}
                    {%- when 3 -%}{{ v2_fact_icon_3 }}
                    {%- when 4 -%}{{ v2_fact_icon_4 }}
                  {%- endcase -%}
                </div>
                <div>
                  <h2 class="v2-product-main__fact-title-{{ section.id }}">{{ title_value }}</h2>
                  <div class="v2-product-main__fact-meta-{{ section.id }}">{{ meta_value }}</div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          <div class="v2-product-main__faq-{{ section.id }}">
            {%- for index in (1..4) -%}
              {%- assign question_key = 'faq_question_' | append: index -%}
              {%- assign answer_key = 'faq_answer_' | append: index -%}
              {%- assign question_value = section.settings[question_key] -%}
              {%- assign answer_value = section.settings[answer_key] -%}
              {%- if question_value != blank -%}
                <details class="v2-product-main__faq-item-{{ section.id }}">
                  <summary>
                    <span class="v2-product-main__faq-question-{{ section.id }}">{{ question_value }}</span>
                    <span class="v2-product-main__faq-toggle-{{ section.id }}" aria-hidden="true"></span>
                  </summary>
                  <div class="v2-product-main__faq-answer-{{ section.id }}">{{ answer_value }}</div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('.v2-product-main-{{ section.id }}');
    if (!root) return;

    var countEl = document.getElementById('V2ProductRevealCount-{{ section.id }}');
    var barEl = document.getElementById('V2ProductRevealBar-{{ section.id }}');
    var fillEl = document.getElementById('V2ProductRevealFill-{{ section.id }}');
    var calloutCopyEl = document.getElementById('V2ProductCalloutCopy-{{ section.id }}');
    var buyBtn = root.querySelector('[data-iris-buy-button]');
    var errorEl = document.getElementById('V2ProductError-{{ section.id }}');
    var quantityEl = document.getElementById('V2ProductQuantity-{{ section.id }}');
    var minusBtn = root.querySelector('[data-quantity-minus]');
    var plusBtn = root.querySelector('[data-quantity-plus]');

    function normalizeQuantity(value) {
      return Math.max(1, Math.min(10, parseInt(value, 10) || 1));
    }

    if (quantityEl) {
      quantityEl.addEventListener('change', function () {
        quantityEl.value = normalizeQuantity(quantityEl.value);
      });
    }

    if (minusBtn && quantityEl) {
      minusBtn.addEventListener('click', function () {
        quantityEl.value = normalizeQuantity((parseInt(quantityEl.value, 10) || 1) - 1);
      });
    }

    if (plusBtn && quantityEl) {
      plusBtn.addEventListener('click', function () {
        quantityEl.value = normalizeQuantity((parseInt(quantityEl.value, 10) || 1) + 1);
      });
    }

    function renderRevealStats(data) {
      var total = Number(data && data.total_count) || 0;
      var editionSize = Number(data && data.collection && data.collection.edition_size) || 10000;
      if (countEl) countEl.textContent = total + ' of ' + editionSize.toLocaleString();
      if (fillEl && barEl) {
        var progressPercent = editionSize > 0 ? Math.min(100, (total / editionSize) * 100) : 0;
        fillEl.style.width = progressPercent + '%';
      }
      if (calloutCopyEl) {
        if (editionSize <= 100) {
          calloutCopyEl.textContent = calloutCopyEl.textContent.replace(
            /\s*No two pieces.*?identical\.?/i,
            ''
          ).trim();
        } else {
          calloutCopyEl.textContent = calloutCopyEl.textContent.replace(
            /No two pieces.*?identical\.?/i,
            'No two pieces in this collection of ' + editionSize.toLocaleString() + ' are identical.'
          );
        }
      }
    }

    function fetchRevealStats(url, allowFallback) {
      return fetch(url, {
        headers: { Accept: 'application/json' },
        cache: 'no-store'
      })
        .then(function (response) {
          if (!response.ok) {
            if (allowFallback && response.status === 404) {
              return fetchRevealStats('/apps/iris/seen-archive?limit=1', false);
            }
            throw new Error('bad_status');
          }
          return response.json();
        })
        .then(renderRevealStats);
    }

    var collectionHandle = '{{ product.handle | escape }}';
    var archiveUrl = '/apps/iris/seen-archive?limit=1';
    if (collectionHandle) {
      archiveUrl += '&collection=' + encodeURIComponent(collectionHandle);
    }

    fetchRevealStats(archiveUrl, Boolean(collectionHandle)).catch(function () {
      if (countEl) countEl.textContent = '—';
    });

    if (!buyBtn) return;

    buyBtn.addEventListener('click', function () {
      var variantId = buyBtn.getAttribute('data-variant-id');
      var productId = buyBtn.getAttribute('data-product-id');
      var productHandle = buyBtn.getAttribute('data-product-handle');
      if (!variantId || buyBtn.disabled) return;
      var quantity = quantityEl ? normalizeQuantity(quantityEl.value) : 1;

      buyBtn.disabled = true;
      if (errorEl) {
        errorEl.hidden = true;
        errorEl.textContent = '';
      }

      function reserveOne() {
        return fetch('/apps/iris/reserve-random', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            product_id: productId,
            product_handle: productHandle
          })
        })
          .then(function (res) {
            if (!res.ok) throw new Error('reserve_failed');
            return res.json();
          });
      }

      function addOne(reservation) {
        if (!reservation || !reservation.irisId || !reservation.reservationToken) {
          throw new Error('bad_response');
        }

        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            id: variantId,
            quantity: 1,
            properties: {
              IRIS_ID: reservation.irisId,
              IRIS_RESERVATION_TOKEN: reservation.reservationToken
            }
          })
        }).then(function (res) {
          if (!res.ok) throw new Error('add_to_cart_failed');
          return res.json();
        });
      }

      var chain = Promise.resolve();
      for (var i = 0; i < quantity; i++) {
        chain = chain.then(reserveOne).then(addOne);
      }

      chain
        .then(function () {
          window.location.assign('/cart');
        })
        .catch(function () {
          if (errorEl) {
            errorEl.hidden = false;
            errorEl.textContent = 'We could not reserve an IRIS right now. Please try again.';
          }
          buyBtn.disabled = false;
        });
    });
  })();
</script>

{% schema %}
{
  "name": "V2 Product Main",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "display_image", "label": "Display image" },
    { "type": "text", "id": "top_badge", "label": "Top badge", "default": "The Unseen Edition" },
    { "type": "text", "id": "bottom_badge", "label": "Bottom badge", "default": "Unseen until revealed" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "IRIS NYC · Physical Collectible Art" },
    { "type": "text", "id": "title_line_1", "label": "Title line 1", "default": "The" },
    { "type": "text", "id": "title_accent", "label": "Title accent", "default": "Unseen" },
    { "type": "text", "id": "title_line_2", "label": "Title line 2", "default": "Edition" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "One piece. Unknown until it is yours." },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>A hand-made original artwork on paper, completed before you receive it. Its number, its composition, its character — already decided. You don't choose your piece. You receive it. Then you reveal it.</p>"
    },
    { "type": "text", "id": "callout_title", "label": "Callout title", "default": "No previews. No selection." },
    {
      "type": "textarea",
      "id": "callout_text",
      "label": "Callout text",
      "default": "Your edition is assigned at random and revealed only after purchase. No two pieces in the collection of 10,000 are identical."
    },
    { "type": "text", "id": "progress_label", "label": "Progress label", "default": "Editions revealed" },
    { "type": "text", "id": "price_caption", "label": "Price caption", "default": "Current release price" },
    { "type": "text", "id": "shipping_line_1", "label": "Shipping line 1", "default": "Shipping calculated at checkout" },
    { "type": "text", "id": "shipping_line_2", "label": "Shipping line 2", "default": "No returns — each piece is unique" },
    { "type": "text", "id": "shipping_line_3", "label": "Shipping line 3", "default": "Delivered in 5–10 business days" },
    { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "Physical gold inside" },
    { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Hand-made original" },
    { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Archived forever" },
    { "type": "text", "id": "feature_4", "label": "Feature 4", "default": "Certificate included" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button label", "default": "Reveal My IRIS" },
    { "type": "text", "id": "archive_button_label", "label": "Archive button label", "default": "View Revealed Archive" },
    { "type": "url", "id": "archive_link", "label": "Archive link" },
    { "type": "header", "content": "Facts" },
    { "type": "text", "id": "fact_title_1", "label": "Fact 1 title", "default": "Unique 4-digit ID" },
    { "type": "text", "id": "fact_meta_1", "label": "Fact 1 meta", "default": "Stamped by hand · No two alike" },
    { "type": "text", "id": "fact_title_2", "label": "Fact 2 title", "default": "Physical Gold — Au 79" },
    { "type": "text", "id": "fact_meta_2", "label": "Fact 2 meta", "default": "Embedded in every piece · Permanence" },
    { "type": "text", "id": "fact_title_3", "label": "Fact 3 title", "default": "Ownership Certificate" },
    { "type": "text", "id": "fact_meta_3", "label": "Fact 3 meta", "default": "Register in the public archive" },
    { "type": "text", "id": "fact_title_4", "label": "Fact 4 title", "default": "Worldwide Shipping" },
    { "type": "text", "id": "fact_meta_4", "label": "Fact 4 meta", "default": "Tracked · Protective packaging" },
    { "type": "header", "content": "FAQ" },
    { "type": "text", "id": "faq_question_1", "label": "FAQ 1 question", "default": "How does the reveal work?" },
    { "type": "richtext", "id": "faq_answer_1", "label": "FAQ 1 answer", "default": "<p>Your IRIS is assigned at random when you purchase. Once you receive the work, scan the NFC tag and activate it to reveal the exact edition in your passport.</p>" },
    { "type": "text", "id": "faq_question_2", "label": "FAQ 2 question", "default": "What is the physical gold?" },
    { "type": "richtext", "id": "faq_answer_2", "label": "FAQ 2 answer", "default": "<p>Each IRIS contains 24K physical gold embedded into the original work. The final gold content is disclosed after activation and also appears in the IRIS passport.</p>" },
    { "type": "text", "id": "faq_question_3", "label": "FAQ 3 question", "default": "Can I return or exchange my piece?" },
    { "type": "richtext", "id": "faq_answer_3", "label": "FAQ 3 answer", "default": "<p>No. Each IRIS is unique and assigned at random. Because the artwork is sealed to the collector at purchase, all sales are final.</p>" },
    { "type": "text", "id": "faq_question_4", "label": "FAQ 4 question", "default": "Shipping & delivery" },
    { "type": "richtext", "id": "faq_answer_4", "label": "FAQ 4 answer", "default": "<p>Orders are packed securely and shipped with tracking. Delivery timelines may vary by destination, but most orders arrive within 5–10 business days.</p>" }
  ],
  "presets": [
    { "name": "V2 Product Main" }
  ]
}
{% endschema %}
