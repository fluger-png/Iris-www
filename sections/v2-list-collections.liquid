{%- liquid
  assign visible_collections = ''
  assign active_count = 0
  assign excluded_handles = 'all,frontpage' | split: ','
-%}

<style>
  .v2-collections-{{ section.id }} {
    --v2c-gold: #c9a84c;
    --v2c-gold-dim: rgba(201, 168, 76, 0.08);
    --v2c-gold-line: rgba(201, 168, 76, 0.2);
    --v2c-black: #080808;
    --v2c-bg: #0a0a08;
    --v2c-panel: #111110;
    --v2c-card: #131311;
    --v2c-border: #1e1e1a;
    --v2c-text: #e8e4dc;
    --v2c-muted: #6a6860;
    --v2c-dim: #2e2e2a;
    --v2c-green: #4caf7d;
    --v2c-green-dim: rgba(76, 175, 125, 0.08);
    background: var(--v2c-bg);
    color: var(--v2c-text);
  }

  .v2-collections-{{ section.id }} * {
    box-sizing: border-box;
  }

  .v2-collections-{{ section.id }} {
    position: relative;
  }

  .v2-collections-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.022;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
    z-index: 0;
  }

  .v2-collections__ticker-{{ section.id }} {
    position: relative;
    z-index: 1;
    overflow: hidden;
    white-space: nowrap;
    padding: 1.3rem 0;
    border-top: 1px solid var(--v2c-border);
    border-bottom: 1px solid var(--v2c-border);
    background: var(--v2c-black);
  }

  .v2-collections__ticker-inner-{{ section.id }} {
    display: inline-flex;
    gap: 6.4rem;
    animation: v2-collections-ticker-{{ section.id }} 28s linear infinite;
  }

  .v2-collections__ticker-item-{{ section.id }} {
    flex-shrink: 0;
    color: var(--v2c-muted);
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-style: italic;
  }

  .v2-collections__ticker-dot-{{ section.id }} {
    color: var(--v2c-gold);
    opacity: 0.3;
  }

  @keyframes v2-collections-ticker-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .v2-collections__header-{{ section.id }} {
    position: relative;
    z-index: 1;
    padding: 6.4rem 5.6rem 5.2rem;
    border-bottom: 1px solid var(--v2c-border);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 4rem;
  }

  .v2-collections__eyebrow-{{ section.id }} {
    margin-bottom: 1.4rem;
    color: var(--v2c-gold);
    opacity: 0.5;
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
  }

  .v2-collections__title-{{ section.id }} {
    margin: 0;
    color: var(--v2c-text);
    font-family: var(--font-heading-family);
    font-size: clamp(4.4rem, 5.5vw, 7.2rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.2rem;
  }

  .v2-collections__title-{{ section.id }} em {
    color: var(--v2c-gold);
    font-style: italic;
  }

  .v2-collections__header-right-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1.2rem;
  }

  .v2-collections__gold-pill-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.8rem 1.6rem;
    background: var(--v2c-gold-dim);
    border: 1px solid var(--v2c-gold-line);
  }

  .v2-collections__gold-dot-{{ section.id }} {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--v2c-gold);
    animation: v2-collections-glow-{{ section.id }} 2s ease-in-out infinite;
  }

  @keyframes v2-collections-glow-{{ section.id }} {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .v2-collections__gold-text-{{ section.id }} {
    color: var(--v2c-gold);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .v2-collections__count-{{ section.id }} {
    color: var(--v2c-muted);
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    letter-spacing: 0.1rem;
  }

  .v2-collections__count-{{ section.id }} span {
    color: var(--v2c-text);
    font-weight: 500;
  }

  .v2-collections__grid-wrap-{{ section.id }} {
    position: relative;
    z-index: 1;
    padding: 4rem 5.6rem 8rem;
  }

  .v2-collections__grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.2rem;
  }

  .v2-collections__card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    background: var(--v2c-card);
    border: 1px solid var(--v2c-border);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.3s ease;
    animation: v2-collections-fade-up-{{ section.id }} 0.5s ease both;
  }

  .v2-collections__card-{{ section.id }}:hover {
    border-color: var(--v2c-gold-line);
  }

  .v2-collections__card-{{ section.id }}:nth-child(1) { animation-delay: 0.05s; }
  .v2-collections__card-{{ section.id }}:nth-child(2) { animation-delay: 0.12s; }
  .v2-collections__card-{{ section.id }}:nth-child(3) { animation-delay: 0.19s; }
  .v2-collections__card-{{ section.id }}:nth-child(4) { animation-delay: 0.26s; }
  .v2-collections__card-{{ section.id }}:nth-child(5) { animation-delay: 0.33s; }
  .v2-collections__card-{{ section.id }}:nth-child(6) { animation-delay: 0.40s; }

  @keyframes v2-collections-fade-up-{{ section.id }} {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .v2-collections__artwork-{{ section.id }} {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--v2c-panel);
  }

  .v2-collections__artwork-bg-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 55%, #141411, #080808);
  }

  .v2-collections__artwork-media-{{ section.id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .v2-collections__artwork-fallback-{{ section.id }} {
    position: relative;
    z-index: 1;
    padding: 2.4rem;
    text-align: center;
    color: var(--v2c-gold);
    font-family: var(--font-heading-family);
    font-size: 2.6rem;
    font-style: italic;
    line-height: 1.1;
  }

  .v2-collections__card-{{ section.id }}:hover .v2-collections__artwork-media-{{ section.id }} {
    transform: scale(1.04);
  }

  .v2-collections__badge-{{ section.id }} {
    position: absolute;
    top: 1.4rem;
    left: 1.4rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0.9rem;
    color: var(--v2c-green);
    background: var(--v2c-green-dim);
    border: 1px solid rgba(76, 175, 125, 0.18);
    font-family: var(--font-body-family);
    font-size: 0.8rem;
    letter-spacing: 0.25rem;
    text-transform: uppercase;
  }

  .v2-collections__badge-dot-{{ section.id }} {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: currentColor;
  }

  .v2-collections__body-{{ section.id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2.4rem 2.6rem 2.6rem;
  }

  .v2-collections__name-{{ section.id }} {
    color: var(--v2c-text);
    font-family: var(--font-heading-family);
    font-size: 2.2rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
  }

  .v2-collections__progress-row-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 0.8rem;
    color: var(--v2c-muted);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  .v2-collections__progress-row-{{ section.id }} strong {
    color: var(--v2c-gold);
    font-weight: 500;
  }

  .v2-collections__track-{{ section.id }} {
    height: 2px;
    background: #1d1c1b;
    position: relative;
    transition: background 0.35s ease;
  }

  .v2-collections__fill-{{ section.id }} {
    display: none;
  }

  .v2-collections__price-row-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--v2c-border);
  }

  .v2-collections__price-{{ section.id }} {
    color: var(--v2c-gold);
    font-family: var(--font-heading-family);
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.04rem;
  }

  .v2-collections__price-label-{{ section.id }} {
    margin-top: 0.3rem;
    color: var(--v2c-muted);
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .v2-collections__cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2rem;
    background: var(--v2c-gold);
    color: var(--v2c-black);
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.25rem;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .v2-collections__card-{{ section.id }}:hover .v2-collections__cta-{{ section.id }} {
    background: #e8c96a;
    gap: 1.4rem;
  }

  .v2-collections__empty-{{ section.id }} {
    position: relative;
    z-index: 1;
    padding: 12rem 5.6rem;
    text-align: center;
  }

  .v2-collections__empty-{{ section.id }} p {
    color: var(--v2c-muted);
    font-family: var(--font-body-family);
    font-size: 1.4rem;
  }

  @media screen and (max-width: 989px) {
    .v2-collections__header-{{ section.id }} {
      padding: 4.8rem 2.4rem 4rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .v2-collections__header-right-{{ section.id }} {
      align-items: flex-start;
    }

    .v2-collections__grid-wrap-{{ section.id }} {
      padding: 3.2rem 2.4rem 5.6rem;
    }

    .v2-collections__grid-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .v2-collections__title-{{ section.id }} {
      font-size: clamp(4rem, 10vw, 6rem);
    }

    .v2-collections__body-{{ section.id }} {
      padding: 2rem;
    }

    .v2-collections__price-row-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

{%- liquid
  case section.settings.sort
    when 'products_high', 'products_low'
      assign sorted_collections = collections | sort: 'all_products_count'
    when 'date', 'date_reversed'
      assign sorted_collections = collections | sort: 'published_at'
    else
      assign sorted_collections = collections | sort: 'title'
  endcase

  if section.settings.sort == 'products_high' or section.settings.sort == 'date_reversed' or section.settings.sort == 'alphabetical_reversed'
    assign sorted_collections = sorted_collections | reverse
  endif

  assign active_total = 0
-%}

<div class="v2-collections-{{ section.id }}">
  <div class="v2-collections__ticker-{{ section.id }}">
    <div class="v2-collections__ticker-inner-{{ section.id }}">
      <span class="v2-collections__ticker-item-{{ section.id }}">Physical artwork <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">0.4g real gold inside every piece <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">NFC · permanent archive <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">Unknown until revealed <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">New York <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">Physical artwork <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">0.4g real gold inside every piece <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">NFC · permanent archive <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">Unknown until revealed <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
      <span class="v2-collections__ticker-item-{{ section.id }}">New York <span class="v2-collections__ticker-dot-{{ section.id }}">◆</span></span>
    </div>
  </div>

  <div class="v2-collections__header-{{ section.id }}">
    <div>
      <div class="v2-collections__eyebrow-{{ section.id }}">IRIS NYC</div>
      <h1 class="v2-collections__title-{{ section.id }}">Active<br><em>Collections</em></h1>
    </div>
    <div class="v2-collections__header-right-{{ section.id }}">
      <div class="v2-collections__gold-pill-{{ section.id }}" data-gold-pill>
        <div class="v2-collections__gold-dot-{{ section.id }}"></div>
        <div class="v2-collections__gold-text-{{ section.id }}">Gold — / g · Min —</div>
      </div>
      <div class="v2-collections__count-{{ section.id }}" data-active-count></div>
    </div>
  </div>

  {%- liquid
    assign rendered_count = 0
  -%}
  <div class="v2-collections__grid-wrap-{{ section.id }}">
    <div class="v2-collections__grid-{{ section.id }}" data-collections-grid>
      {%- for collection in sorted_collections limit: 30 -%}
        {%- unless excluded_handles contains collection.handle -%}
          {%- liquid
            assign first_product = collection.products.first
            assign card_link = collection.url
            assign archive_handle = collection.handle
            if first_product != blank
              assign card_link = first_product.url
              assign archive_handle = first_product.handle
            endif

            assign display_title = collection.title
            if archive_handle == 'iris-the-unseen-edition' or archive_handle == 'iris-collection' or archive_handle == 'iris'
              assign display_title = 'IRIS Collection'
            endif

            assign card_image = collection.image
            if card_image == blank and first_product != blank
              assign card_image = first_product.featured_media.preview_image | default: first_product.featured_image
            endif

            assign card_media_class = 'v2-collections__artwork-media-' | append: section.id

            assign card_price = nil
            if first_product != blank and first_product.price
              assign card_price = first_product.price | money_without_trailing_zeros
            endif

            assign rendered_count = rendered_count | plus: 1
          -%}
          <a
            href="{{ card_link }}"
            class="v2-collections__card-{{ section.id }}"
            data-collection-card
            data-collection-handle="{{ archive_handle | escape }}"
            data-collection-title="{{ display_title | escape }}"
          >
            <div class="v2-collections__artwork-{{ section.id }}">
              <div class="v2-collections__artwork-bg-{{ section.id }}"></div>
              {%- if card_image != blank -%}
                {{ card_image | image_url: width: 1200 | image_tag:
                  class: card_media_class,
                  loading: 'lazy',
                  alt: display_title
                }}
              {%- else -%}
                <div class="v2-collections__artwork-fallback-{{ section.id }}">{{ display_title }}</div>
              {%- endif -%}
              <div class="v2-collections__badge-{{ section.id }}"><span class="v2-collections__badge-dot-{{ section.id }}"></span>Active</div>
            </div>

            <div class="v2-collections__body-{{ section.id }}">
              <div class="v2-collections__name-{{ section.id }}">&ldquo;{{ display_title }}&rdquo;</div>

              <div class="v2-collections__progress-{{ section.id }}">
                <div class="v2-collections__progress-row-{{ section.id }}">
                  <span>Editions revealed</span>
                  <strong data-collection-count>—</strong>
                </div>
                <div class="v2-collections__track-{{ section.id }}">
                  <div class="v2-collections__fill-{{ section.id }}" data-collection-fill data-empty="true"></div>
                </div>
              </div>

              <div class="v2-collections__price-row-{{ section.id }}">
                <div>
                  <div class="v2-collections__price-{{ section.id }}">{{ card_price | default: '—' }}</div>
                  <div class="v2-collections__price-label-{{ section.id }}">Current price</div>
                </div>
                <div class="v2-collections__cta-{{ section.id }}">Reveal →</div>
              </div>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>

    {%- if rendered_count == 0 -%}
      <div class="v2-collections__empty-{{ section.id }}">
        <p>No collections are visible yet.</p>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    var sectionId = {{ section.id | json }};
    var root = document.querySelector('.v2-collections-' + sectionId);
    if (!root) return;

    function formatNumber(value) {
      return new Intl.NumberFormat('en-US').format(value);
    }

    function updateGoldPill() {
      var pill = root.querySelector('[data-gold-pill] .v2-collections__gold-text-' + sectionId);
      if (!pill) return;
      var cacheKey = 'iris-live-gold-price';
      var cached = null;
      try {
        var raw = localStorage.getItem(cacheKey);
        if (raw) {
          var parsed = JSON.parse(raw);
          if (parsed && typeof parsed.value === 'number' && typeof parsed.ts === 'number' && (Date.now() - parsed.ts) < (30 * 60 * 1000)) {
            cached = parsed.value;
          }
        }
      } catch (_) {}

      function setValue(price) {
        var minPrice = Math.ceil(((price * 0.4) + 20) * 1.5);
        pill.textContent = 'Gold $' + price.toFixed(2) + ' / g · Min $' + minPrice;
      }

      if (typeof cached === 'number') {
        setValue(cached);
        return;
      }

      fetch('/apps/iris/gold-price', { headers: { Accept: 'application/json' } })
        .then(function(res) { return res.ok ? res.json() : null; })
        .then(function(data) {
          var price = Number(data && data.price_usd_g);
          if (!Number.isFinite(price) || price <= 0) return;
          try {
            localStorage.setItem(cacheKey, JSON.stringify({ value: price, ts: Date.now() }));
          } catch (_) {}
          setValue(price);
        })
        .catch(function() {});
    }

    function updateActiveCount() {
      var countEl = root.querySelector('[data-active-count]');
      if (!countEl) return;
      var total = root.querySelectorAll('[data-collection-card]').length;
      countEl.innerHTML = '<span>' + total + '</span> editions currently active';
    }

    function hydrateCards() {
      var cards = root.querySelectorAll('[data-collection-card]');
      cards.forEach(function(card) {
        var handle = card.getAttribute('data-collection-handle');
        var countEl = card.querySelector('[data-collection-count]');
        var fillEl = card.querySelector('[data-collection-fill]');
        var trackEl = fillEl ? fillEl.parentElement : null;
        if (!handle || !countEl || !fillEl) return;

        fetch('/apps/iris/seen-archive?limit=1&collection=' + encodeURIComponent(handle), {
          headers: { Accept: 'application/json' }
        })
          .then(function(res) { return res.ok ? res.json() : null; })
          .then(function(data) {
            var total = Number(data && data.total_count);
            var editionSize = Number(data && data.collection && data.collection.edition_size);
            if (!Number.isFinite(total) || total < 0) total = 0;
            if (!Number.isFinite(editionSize) || editionSize <= 0) {
              if (handle === 'iris-the-unseen-edition' || handle === 'iris-collection' || handle === 'iris') {
                editionSize = 10000;
              } else {
                editionSize = total;
              }
            }
            countEl.textContent = formatNumber(total) + ' of ' + formatNumber(editionSize);
            var progress = editionSize > 0 ? Math.min(100, (total / editionSize) * 100) : 0;
            var visibleProgress = total > 0 ? Math.max(progress, 1) : 0;
            if (trackEl) {
              if (visibleProgress > 0) {
                trackEl.style.background = 'linear-gradient(90deg, #c9a84c 0%, #c9a84c ' + visibleProgress + '%, #1d1c1b ' + visibleProgress + '%, #1d1c1b 100%)';
              } else {
                trackEl.style.background = '#1d1c1b';
              }
            }
          })
          .catch(function() {
            countEl.textContent = '—';
          });
      });
    }

    updateGoldPill();
    updateActiveCount();
    hydrateCards();
  })();
</script>

{% schema %}
{
  "name": "V2 Collections Page",
  "settings": [
    {
      "type": "select",
      "id": "sort",
      "label": "Sort",
      "options": [
        { "value": "alphabetical", "label": "Alphabetical" },
        { "value": "alphabetical_reversed", "label": "Alphabetical, reversed" },
        { "value": "date_reversed", "label": "Date, newest first" },
        { "value": "date", "label": "Date, oldest first" },
        { "value": "products_high", "label": "Products, high to low" },
