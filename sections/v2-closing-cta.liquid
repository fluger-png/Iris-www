{%- style -%}
  .v2-closing-cta-{{ section.id }} {
    --v2-gold: #c9a84c;
    --v2-gold-light: #e8cc7a;
    --v2-gold-dim: #7a6330;
    --v2-bg: #101010;
    --v2-border: rgba(201, 168, 76, 0.15);
    --v2-text: #ede8df;
    --v2-text-mid: #a89f90;
    background: #101010;
    color: var(--v2-text);
    border-top: 1px solid var(--v2-border);
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-closing-cta__wrap-{{ section.id }} {
    max-width: 118rem;
    margin: 0 auto;
    padding: 12rem 8rem;
    text-align: center;
  }

  .v2-closing-cta__eyebrow-{{ section.id }} {
    margin: 0 0 1.6rem;
    color: var(--v2-gold-dim);
    text-transform: uppercase;
    letter-spacing: 0.42rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
  }

  .v2-closing-cta__title-{{ section.id }} {
    margin: 0 0 2.2rem;
    font-family: var(--font-heading-family);
    font-size: clamp(3.6rem, 5vw, 6.8rem);
    line-height: 1.04;
    letter-spacing: 0.03em;
    font-weight: 400;
    color: var(--v2-text) !important;
  }

  .v2-closing-cta__title-{{ section.id }},
  .v2-closing-cta__title-{{ section.id }} * {
    color: var(--v2-text) !important;
  }

  .v2-closing-cta__title-{{ section.id }} em,
  .v2-closing-cta__title-{{ section.id }} em * {
    color: var(--v2-gold) !important;
    font-style: italic;
    font-weight: 400;
  }

  .v2-closing-cta__body-{{ section.id }} {
    max-width: 72rem;
    margin: 0 auto 4rem;
    color: var(--v2-text-mid);
    font-size: 1.75rem;
    line-height: 1.8;
  }

  .v2-closing-cta__actions-{{ section.id }} {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.6rem;
  }

  .v2-closing-cta__button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 5.8rem;
    padding: 1.6rem 3.2rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.24rem;
    font-size: 1.1rem;
    font-family: var(--font-body-family);
    transition: all 0.25s ease;
  }

  .v2-closing-cta__button-{{ section.id }}.is-primary {
    background: var(--v2-gold);
    color: #080808;
  }

  .v2-closing-cta__button-{{ section.id }}.is-primary:hover {
    background: var(--v2-gold-light);
  }

  .v2-closing-cta__button-{{ section.id }}.is-secondary {
    border: 1px solid var(--v2-border);
    color: var(--v2-gold);
    background: rgba(201, 168, 76, 0.04);
  }

  .v2-closing-cta__button-{{ section.id }}.is-secondary:hover {
    border-color: rgba(201, 168, 76, 0.45);
    background: rgba(201, 168, 76, 0.08);
  }

  @media screen and (max-width: 989px) {
    .v2-closing-cta__wrap-{{ section.id }} {
      padding: 9rem 3.2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .v2-closing-cta__wrap-{{ section.id }} {
      padding: 7rem 2rem;
    }

    .v2-closing-cta__eyebrow-{{ section.id }} {
      letter-spacing: 0.28rem;
      font-size: 0.9rem;
    }

    .v2-closing-cta__body-{{ section.id }} {
      font-size: 1.6rem;
      line-height: 1.75;
    }

    .v2-closing-cta__actions-{{ section.id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .v2-closing-cta__button-{{ section.id }} {
      width: 100%;
    }
  }
{%- endstyle -%}

<section class="v2-closing-cta-{{ section.id }}">
  <div class="v2-closing-cta__wrap-{{ section.id }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="v2-closing-cta__eyebrow-{{ section.id }}">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="v2-closing-cta__title-{{ section.id }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <div class="v2-closing-cta__body-{{ section.id }}">{{ section.settings.body }}</div>
    {%- endif -%}

    <div class="v2-closing-cta__actions-{{ section.id }}">
      {%- if section.settings.primary_label != blank -%}
        <a
          class="v2-closing-cta__button-{{ section.id }} is-primary"
          href="{{ section.settings.primary_link | default: '/products/iris-the-unseen-edition' }}"
        >
          {{ section.settings.primary_label | escape }}
        </a>
      {%- endif -%}

      {%- if section.settings.secondary_label != blank -%}
        <a
          class="v2-closing-cta__button-{{ section.id }} is-secondary"
          href="{{ section.settings.secondary_link | default: '/pages/iris-archive' }}"
        >
          {{ section.settings.secondary_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "V2 Closing CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Acquire Your IRIS"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Begin the reveal and claim your <em>IRIS</em>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Purchase from the current edition, activate the piece through NFC, and unlock the passport that makes your work fully yours.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop the Edition"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View the Archive"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "V2 Closing CTA"
    }
  ]
}
{% endschema %}
