{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<style>
  .footer {
    --iris-footer-bg: #101010;
    --iris-footer-surface: #171717;
    --iris-footer-border: rgba(201, 168, 76, 0.15);
    --iris-footer-text: #ede8df;
    --iris-footer-text-dim: #a89f90;
    --iris-footer-text-muted: #8f8779;
    --iris-footer-gold: #c9a84c;
    background: var(--iris-footer-bg) !important;
    color: var(--iris-footer-text) !important;
    border-top: 1px solid var(--iris-footer-border);
  }

  .footer .footer__content-top,
  .footer .footer__content-bottom {
    display: none !important;
  }

  .iris-footer-v2 {
    position: relative;
    overflow: hidden;
  }

  .iris-footer-v2::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.35;
    pointer-events: none;
  }

  .iris-footer-v2__newsletter {
    position: relative;
    z-index: 1;
    padding: 12rem 2rem 11rem;
    text-align: center;
    border-bottom: 1px solid var(--iris-footer-border);
  }

  .iris-footer-v2__heading {
    margin: 0 0 2.4rem;
    color: var(--iris-footer-text);
    font-family: "Cormorant Garamond", var(--font-heading-family), serif;
    font-size: clamp(4.8rem, 5vw, 6.8rem);
    line-height: 1.06;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .iris-footer-v2__subcopy {
    margin: 0;
    color: var(--iris-footer-text-muted);
    font-family: "Cormorant Garamond", var(--font-heading-family), serif;
    font-style: italic;
    font-size: 1.8rem;
    line-height: 1.9;
  }

  .iris-footer-v2__subcopy + .iris-footer-v2__subcopy {
    margin-top: 0.2rem;
  }

  .iris-footer-v2__form {
    max-width: 57rem;
    margin: 4.2rem auto 0;
  }

  .iris-footer-v2 .newsletter-form__field-wrapper {
    max-width: none;
  }

  .iris-footer-v2 .field {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 11rem;
    align-items: stretch;
    border: 1px solid var(--iris-footer-border);
    background: #161616;
    min-height: 6.2rem;
  }

  .iris-footer-v2 .field__input {
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    color: var(--iris-footer-text) !important;
    padding: 2rem 2.4rem !important;
    font-size: 1.3rem;
    letter-spacing: 0.22rem;
    text-transform: lowercase;
    font-family: var(--font-body-family);
  }

  .iris-footer-v2 .field__label {
    color: var(--iris-footer-text-muted) !important;
    left: 2.4rem !important;
  }

  .iris-footer-v2 .newsletter-form__button {
    position: static !important;
    width: auto !important;
    height: auto !important;
    min-width: 11rem;
    background: var(--iris-footer-gold);
    color: #080808 !important;
    border-left: 1px solid var(--iris-footer-border);
    font-size: 1.2rem;
    letter-spacing: 0.28rem;
    text-transform: uppercase;
    font-family: var(--font-body-family);
  }

  .iris-footer-v2 .newsletter-form__button .svg-wrapper {
    display: none;
  }

  .iris-footer-v2__microcopy {
    margin: 3rem auto 0;
    max-width: 70rem;
    color: var(--iris-footer-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.44rem;
    font-size: 1.25rem;
    line-height: 1.9;
    font-style: italic;
    font-family: var(--font-body-family);
  }

  .iris-footer-v2__bottom {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: center;
    padding: 4rem 6rem 3.6rem;
  }

  .iris-footer-v2__brand {
    color: var(--iris-footer-gold) !important;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5rem;
    font-size: 1.8rem;
    font-family: "Cormorant Garamond", var(--font-heading-family), serif;
    justify-self: start;
  }

  .iris-footer-v2__menu {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3.2rem;
    flex-wrap: wrap;
  }

  .iris-footer-v2__menu a {
    color: var(--iris-footer-text-muted) !important;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.26rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
    transition: color 0.2s ease;
  }

  .iris-footer-v2__menu a:hover {
    color: var(--iris-footer-gold) !important;
  }

  .iris-footer-v2__meta {
    justify-self: end;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    color: var(--iris-footer-text-muted);
    letter-spacing: 0.22rem;
    font-size: 1rem;
    font-family: var(--font-body-family);
    text-transform: none;
  }

  .iris-footer-v2__meta-dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--iris-footer-gold);
    flex-shrink: 0;
  }

  .footer .footer__content-top,
  .footer .footer__content-bottom {
    background: transparent !important;
  }

  .footer .footer__content-top {
    border-bottom: 1px solid var(--iris-footer-border);
  }

  .footer .footer__blocks-wrapper,
  .footer .footer__content-bottom-wrapper {
    border-color: var(--iris-footer-border);
  }

  .footer .footer-block__heading,
  .footer .footer-block__heading *,
  .footer .footer__copyright,
  .footer .footer__copyright *,
  .footer .footer__gold,
  .footer .footer__gold * {
    color: var(--iris-footer-text) !important;
  }

  .footer .footer-block__details-content,
  .footer .footer-block__details-content *,
  .footer .rte,
  .footer .rte *,
  .footer .copyright__content,
  .footer .footer__gold-label {
    color: var(--iris-footer-text-dim) !important;
  }

  .footer .list-menu__item--link,
  .footer .link--text,
  .footer .policies a,
  .footer .footer__copyright a {
    color: var(--iris-footer-text-dim) !important;
    transition: color 0.2s ease;
  }

  .footer .list-menu__item--link:hover,
  .footer .link--text:hover,
  .footer .policies a:hover,
  .footer .footer__copyright a:hover {
    color: var(--iris-footer-gold) !important;
  }

  .footer .footer__gold-value {
    color: var(--iris-footer-gold) !important;
  }

  .footer .newsletter-form__field-wrapper .field {
    border: 1px solid var(--iris-footer-border);
    background: var(--iris-footer-surface);
  }

  .footer .field__input,
  .footer .field__label,
  .footer .newsletter-form__button,
  .footer .localization-form select,
  .footer .localization-form button {
    color: var(--iris-footer-text) !important;
  }

  .footer .field__input::placeholder {
    color: var(--iris-footer-text-muted);
  }

  .footer .list-social__link,
  .footer .icon {
    color: var(--iris-footer-text-dim);
  }

  .footer .list-social__link:hover,
  .footer .list-social__link:hover .icon {
    color: var(--iris-footer-gold);
  }

  .footer__social-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .footer__gold {
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: inherit;
  }
  .footer__gold-label { opacity: 0.7; }
  .footer__gold-value { font-weight: 600; }

  @media screen and (max-width: 989px) {
    .iris-footer-v2__bottom {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 3.2rem 2rem 3rem;
    }

    .iris-footer-v2__brand,
    .iris-footer-v2__meta {
      justify-self: center;
    }
  }

  @media screen and (max-width: 749px) {
    .iris-footer-v2__newsletter {
      padding: 8rem 2rem 7rem;
    }

    .iris-footer-v2__heading {
      font-size: clamp(3.8rem, 9vw, 5.2rem);
    }

    .iris-footer-v2__subcopy {
      font-size: 1.6rem;
      line-height: 1.8;
    }

    .iris-footer-v2 .field {
      grid-template-columns: 1fr;
    }

    .iris-footer-v2 .newsletter-form__button {
      min-height: 5.6rem;
      border-left: 0;
      border-top: 1px solid var(--iris-footer-border);
    }

    .iris-footer-v2__microcopy {
      font-size: 1.05rem;
      letter-spacing: 0.26rem;
    }

    .iris-footer-v2__menu {
      gap: 1.6rem 2.2rem;
    }

    .iris-footer-v2__brand {
      letter-spacing: 0.34rem;
    }
  }
</style>

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="iris-footer-v2">
    <div class="iris-footer-v2__newsletter page-width">
      <h2 class="iris-footer-v2__heading">{{ section.settings.newsletter_title | default: 'Be first when new editions drop' }}</h2>

      <p class="iris-footer-v2__subcopy">{{ section.settings.newsletter_subtext_1 }}</p>
      <p class="iris-footer-v2__subcopy">{{ section.settings.newsletter_subtext_2 }}</p>

      {%- if section.settings.newsletter_enable -%}
        <div class="iris-footer-v2__form">
          {%- form 'customer', id: 'ContactFooterV2', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterFormV2--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooterV2-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooterV2-success"
                  {% endif %}
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'your@email.com' }}"
                  required
                >
                <label class="field__label" for="NewsletterFormV2--{{ section.id }}">
                  {{ section.settings.newsletter_placeholder | default: 'your@email.com' }}
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="SubscribeV2"
                  aria-label="{{ section.settings.newsletter_button_label | default: 'Join' }}"
                >
                  {{ section.settings.newsletter_button_label | default: 'Join' }}
                </button>
              </div>
              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="ContactFooterV2-error">
                  {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="ContactFooterV2-success"
                tabindex="-1"
                autofocus
              >
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      <p class="iris-footer-v2__microcopy">{{ section.settings.newsletter_microcopy }}</p>
    </div>

    <div class="iris-footer-v2__bottom page-width">
      <a class="iris-footer-v2__brand" href="{{ routes.root_url }}">{{ section.settings.footer_brand_label }}</a>

      <nav class="iris-footer-v2__menu" aria-label="Footer">
        {%- if section.settings.bottom_menu != blank -%}
          {%- for link in section.settings.bottom_menu.links -%}
            <a href="{{ link.url }}">{{ link.title | escape }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/products/iris-the-unseen-edition">Shop</a>
          <a href="/pages/iris-archive">Archive</a>
          <a href="/pages/about">About</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/policies/shipping-policy">Shipping</a>
          <a href="/policies/privacy-policy">Privacy</a>
        {%- endif -%}
      </nav>

      <div class="iris-footer-v2__meta">
        <span class="iris-footer-v2__meta-dot"></span>
        <span>{{ section.settings.footer_meta_text }}</span>
      </div>
    </div>
  </div>

  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width">
        {%- if section.blocks.size > 0 -%}
          {%- liquid
            if section.blocks.size == 9
              assign footer_grid_class = 'grid--3-col-tablet'
            elsif section.blocks.size > 6
              assign footer_grid_class = 'grid--4-col-desktop'
            elsif section.blocks.size > 4
              assign footer_grid_class = 'grid--3-col-tablet'
            endif
          -%}
          <div
            class="footer__blocks-wrapper grid grid--1-col grid--2-col grid--4-col-tablet {{ footer_grid_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- for block in section.blocks -%}
              <div
                class="footer-block grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- when 'link_list' -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social' -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                    <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                      {%- if block.settings.image != blank -%}
                        {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ block.settings.image_width }}px);"
                        >
                          <img
                            srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                            src="{{ block.settings.image | image_url: width: 760 }}"
                            alt="{{ block.settings.image.alt | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                          >
                        </div>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div
          class="footer-block--newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {%- if section.settings.newsletter_enable -%}
            <div class="footer-block__newsletter">
              {%- if section.settings.newsletter_heading != blank -%}
                <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
              {%- endif -%}
              {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-form__field-wrapper">
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="ContactFooter-error"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="ContactFooter-success"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                    <label class="field__label" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      id="Subscribe"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-arrow.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="ContactFooter-error">
                      <span class="svg-wrapper">
                        {{- 'icon-error.svg' | inline_asset_content -}}
                      </span>
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-success.svg' | inline_asset_content -}}
                    </span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- endif -%}

          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_social and has_social_icons -%}
            <div class="footer__social-row">
              {%- render 'social-icons', class: 'footer__list-social' -%}
              {%- if section.settings.show_gold_price -%}
                <div class="footer__gold" data-gold-price>
                  <span class="footer__gold-label">Gold (USD/g):</span>
                  <span class="footer__gold-value">—</span>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

  <div
    class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterLanguageLabel">
                  {{ 'localization.language_label' | t }}
                </h2>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>
      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content"
          >&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
        </small>
        <small class="copyright__content">{{ powered_by_link }}</small>
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            <li>
              <small class="copyright__content"><a href="/pages/iris-points">Partnership</a></small>
            </li>
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <small class="copyright__content"
                    ><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small
                  >
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<script>
  (function () {
    var el = document.querySelector('[data-gold-price]');
    if (!el) return;
    var valueEl = el.querySelector('.footer__gold-value');
    var cacheKey = 'iris_goldapi_usd_g';
    var ttl = 8 * 60 * 60 * 1000;

    function setValue(text) {
      if (valueEl) valueEl.textContent = text;
    }

    function readCache() {
      try {
        var raw = localStorage.getItem(cacheKey);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (!parsed || !parsed.value || !parsed.ts) return null;
        if (Date.now() - parsed.ts > ttl) return null;
        return parsed.value;
      } catch (e) {
        return null;
      }
    }

    function writeCache(value) {
      try {
        localStorage.setItem(cacheKey, JSON.stringify({ value: value, ts: Date.now() }));
      } catch (e) {}
    }

    function fetchPrice() {
      var cached = readCache();
      if (cached) {
        setValue(cached);
        return;
      }

      fetch('/apps/iris/gold-price', { headers: { 'Accept': 'application/json' } })
        .then(function (res) {
          if (!res.ok) throw new Error('bad_status');
          return res.json();
        })
        .then(function (data) {
          var perGram = data.price_usd_g;
          if (!perGram) throw new Error('missing_price');
          var formatted = '$' + Number(perGram).toFixed(2);
          setValue(formatted);
          writeCache(formatted);
        })
        .catch(function () {
          setValue('—');
        });
    }

    fetchPrice();
    setInterval(fetchPrice, ttl);
  })();
</script>

