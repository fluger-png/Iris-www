{%- style -%}
  .v2-what-is-iris-{{ section.id }} {
    --wis-gold: #c9a84c;
    --wis-gold-dim: rgba(201, 168, 76, 0.08);
    --wis-gold-line: rgba(201, 168, 76, 0.2);
    --wis-black: #080808;
    --wis-bg: #0a0a08;
    --wis-ink: #0e0e0c;
    --wis-border: #1e1e1a;
    --wis-text: #e8e4dc;
    --wis-muted: #a59f93;
    --wis-dim: #6a6860;
    background: var(--wis-bg);
    color: var(--wis-text);
    position: relative;
    overflow: hidden;
  }

  .v2-what-is-iris-{{ section.id }} *,
  .v2-what-is-iris-{{ section.id }} *::before,
  .v2-what-is-iris-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .v2-what-is-iris-{{ section.id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    z-index: 0;
  }

  .v2-what-is-iris__surface-{{ section.id }} {
    position: relative;
    z-index: 1;
  }

  .v2-what-is-iris__label-{{ section.id }} {
    display: block;
    margin-bottom: 2.2rem;
    color: var(--wis-gold);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.38rem;
    line-height: 1.2;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .v2-what-is-iris__gold-em-{{ section.id }} {
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__ticker-{{ section.id }} {
    overflow: hidden;
    white-space: nowrap;
    padding: 1.5rem 0;
    border-top: 1px solid var(--wis-border);
    border-bottom: 1px solid var(--wis-border);
    background: var(--wis-black);
  }

  .v2-what-is-iris__ticker-inner-{{ section.id }} {
    display: inline-flex;
    gap: 5.2rem;
    min-width: max-content;
    animation: v2WhatIsIrisTicker-{{ section.id }} 28s linear infinite;
  }

  .v2-what-is-iris__ticker-item-{{ section.id }} {
    color: var(--wis-muted);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.22rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__ticker-dot-{{ section.id }} {
    color: var(--wis-gold);
    opacity: 0.6;
  }

  @keyframes v2WhatIsIrisTicker-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .v2-what-is-iris__hero-{{ section.id }} {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12rem 5.6rem 7rem;
    position: relative;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__hero-eye-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(80vw, 110rem);
    opacity: 0.03;
    pointer-events: none;
  }

  .v2-what-is-iris__hero-title-{{ section.id }} {
    margin: 0 0 3.8rem;
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: clamp(6.4rem, 8.6vw, 12.8rem);
    font-weight: 400;
    line-height: 0.93;
    letter-spacing: -0.22rem;
  }

  .v2-what-is-iris__hero-title-{{ section.id }} em {
    display: block;
    color: var(--wis-gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-what-is-iris__hero-body-{{ section.id }} {
    max-width: 74rem;
    margin: 0 auto 5.4rem;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 2.1vw, 3rem);
    font-style: italic;
    line-height: 1.62;
  }

  .v2-what-is-iris__hero-specs-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    border: 1px solid var(--wis-border);
    background: rgba(8, 8, 8, 0.38);
  }

  .v2-what-is-iris__hero-spec-{{ section.id }} {
    min-width: 18rem;
    padding: 2.2rem 4rem 2.1rem;
    text-align: center;
    border-right: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__hero-spec-{{ section.id }}:last-child {
    border-right: 0;
  }

  .v2-what-is-iris__hero-spec-value-{{ section.id }} {
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    line-height: 1;
  }

  .v2-what-is-iris__hero-spec-label-{{ section.id }} {
    margin-top: 0.7rem;
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__scroll-{{ section.id }} {
    position: absolute;
    left: 50%;
    bottom: 3.2rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .v2-what-is-iris__scroll-{{ section.id }} span {
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__scroll-line-{{ section.id }} {
    width: 1px;
    height: 3.8rem;
    background: linear-gradient(to bottom, var(--wis-gold), transparent);
    opacity: 0.45;
  }

  .v2-what-is-iris__split-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__split-{{ section.id }}--dark {
    background: var(--wis-ink);
  }

  .v2-what-is-iris__split-left-{{ section.id }},
  .v2-what-is-iris__split-right-copy-{{ section.id }} {
    padding: 13rem 6rem;
  }

  .v2-what-is-iris__split-left-{{ section.id }} {
    border-right: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__split-title-{{ section.id }},
  .v2-what-is-iris__reveal-title-{{ section.id }},
  .v2-what-is-iris__section-title-{{ section.id }},
  .v2-what-is-iris__closing-title-{{ section.id }} {
    margin: 0 0 3rem;
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: clamp(4.6rem, 5vw, 7.6rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.12rem;
  }

  .v2-what-is-iris__copy-{{ section.id }} p,
  .v2-what-is-iris__closing-copy-{{ section.id }} {
    margin: 0 0 1.9rem;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.75rem;
    line-height: 1.82;
  }

  .v2-what-is-iris__spec-list-{{ section.id }} {
    margin-top: 4.4rem;
    border-top: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__spec-row-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__spec-key-{{ section.id }} {
    width: 13rem;
    flex-shrink: 0;
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__spec-val-{{ section.id }} {
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 1.55rem;
    line-height: 1.5;
  }

  .v2-what-is-iris__visual-{{ section.id }} {
    padding: 13rem 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-what-is-iris__frame-svg-{{ section.id }} {
    width: 100%;
    max-width: 42rem;
  }

  .v2-what-is-iris__gold-visual-{{ section.id }} {
    position: relative;
    width: 32rem;
    height: 32rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-what-is-iris__gold-ring-{{ section.id }} {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(201, 168, 76, 0.1);
  }

  .v2-what-is-iris__gold-ring-{{ section.id }}--two {
    inset: 4.8rem;
    border-color: rgba(201, 168, 76, 0.18);
  }

  .v2-what-is-iris__gold-ring-{{ section.id }}--three {
    inset: 9.2rem;
    border-color: rgba(201, 168, 76, 0.28);
  }

  .v2-what-is-iris__gold-sphere-{{ section.id }} {
    width: 7.8rem;
    height: 7.8rem;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #f5d665, #936116);
    box-shadow: 0 0 4rem rgba(201, 168, 76, 0.18);
  }

  .v2-what-is-iris__gold-tag-{{ section.id }} {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    white-space: nowrap;
  }

  .v2-what-is-iris__gold-num-{{ section.id }} {
    display: block;
    color: var(--wis-gold);
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    line-height: 1;
  }

  .v2-what-is-iris__gold-label-{{ section.id }} {
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.28rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__blockquote-{{ section.id }} {
    margin-top: 3.4rem;
    padding-left: 2.2rem;
    border-left: 1px solid var(--wis-gold);
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 2.15rem;
    font-style: italic;
    line-height: 1.6;
  }

  .v2-what-is-iris__identity-visual-{{ section.id }} {
    padding: 13rem 6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.4rem;
  }

  .v2-what-is-iris__card-{{ section.id }} {
    width: 100%;
    max-width: 50rem;
    padding: 3rem;
    border: 1px solid var(--wis-border);
    background: var(--wis-ink);
  }

  .v2-what-is-iris__archive-card-{{ section.id }} {
    background: var(--wis-gold-dim);
    border-color: var(--wis-gold-line);
  }

  .v2-what-is-iris__card-label-{{ section.id }} {
    margin-bottom: 1.5rem;
    color: var(--wis-gold);
    opacity: 0.72;
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__card-title-{{ section.id }} {
    margin: 0 0 0.9rem;
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 2.45rem;
    font-style: italic;
    font-weight: 400;
  }

  .v2-what-is-iris__card-meta-{{ section.id }} {
    margin-bottom: 1.5rem;
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    letter-spacing: 0.26rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__card-body-{{ section.id }} {
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.55rem;
    line-height: 1.7;
  }

  .v2-what-is-iris__scan-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: 1.3rem;
  }

  .v2-what-is-iris__scan-dot-{{ section.id }} {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: #4caf7d;
  }

  .v2-what-is-iris__scan-label-{{ section.id }} {
    color: #4caf7d;
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__archive-row-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    line-height: 1.55;
  }

  .v2-what-is-iris__archive-row-{{ section.id }}:last-child {
    border-bottom: 0;
  }

  .v2-what-is-iris__archive-row-{{ section.id }} span {
    color: var(--wis-text);
  }

  .v2-what-is-iris__reveal-{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: 15rem 5.6rem 13rem;
    text-align: center;
    border-bottom: 1px solid var(--wis-border);
    background: var(--wis-black);
  }

  .v2-what-is-iris__reveal-watermark-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 168, 76, 0.04);
    font-family: var(--font-heading-family);
    font-size: clamp(18rem, 22vw, 34rem);
    font-style: italic;
    font-weight: 400;
    pointer-events: none;
    white-space: nowrap;
  }

  .v2-what-is-iris__reveal-title-{{ section.id }} em,
  .v2-what-is-iris__closing-title-{{ section.id }} em {
    color: var(--wis-gold);
    font-style: italic;
    font-weight: 400;
  }

  .v2-what-is-iris__reveal-rule-{{ section.id }} {
    width: 1px;
    height: 5.2rem;
    margin: 4.2rem auto;
    background: linear-gradient(to bottom, transparent, var(--wis-gold), transparent);
    opacity: 0.48;
  }

  .v2-what-is-iris__reveal-body-{{ section.id }} {
    max-width: 72rem;
    margin: 0 auto 5.6rem;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.85rem;
    line-height: 1.84;
  }

  .v2-what-is-iris__reveal-steps-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--wis-border);
  }

  .v2-what-is-iris__reveal-step-{{ section.id }} {
    padding: 4.2rem 3.4rem;
    background: var(--wis-bg);
    text-align: left;
  }

  .v2-what-is-iris__reveal-step-{{ section.id }}--highlight {
    background: #0f0d08;
  }

  .v2-what-is-iris__reveal-num-{{ section.id }} {
    margin-bottom: 1.2rem;
    color: var(--wis-dim);
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.28rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__reveal-step-title-{{ section.id }} {
    margin-bottom: 1rem;
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 3.2rem;
    line-height: 1.05;
  }

  .v2-what-is-iris__reveal-step-{{ section.id }}--highlight .v2-what-is-iris__reveal-step-title-{{ section.id }} {
    color: var(--wis-gold);
  }

  .v2-what-is-iris__reveal-step-{{ section.id }} p {
    margin: 0;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.45rem;
    line-height: 1.78;
  }

  .v2-what-is-iris__aesthetics-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__aesthetics-left-{{ section.id }} {
    padding: 13rem 6rem;
    border-right: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__aesthetics-right-{{ section.id }} {
    padding: 13rem 6rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 3rem;
  }

  .v2-what-is-iris__thought-marker-{{ section.id }} {
    margin-bottom: 1.1rem;
    color: var(--wis-gold);
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .v2-what-is-iris__thought-{{ section.id }} p {
    margin: 0;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.55rem;
    line-height: 1.78;
  }

  .v2-what-is-iris__thought-{{ section.id }} em {
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__collab-{{ section.id }} {
    padding: 13rem 5.6rem;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__collab-header-{{ section.id }} {
    max-width: 78rem;
    margin-bottom: 5.2rem;
  }

  .v2-what-is-iris__collab-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--wis-border);
  }

  .v2-what-is-iris__collab-card-{{ section.id }} {
    padding: 3.4rem 2.8rem;
    background: var(--wis-bg);
  }

  .v2-what-is-iris__collab-card--featured-{{ section.id }} {
    background: #0d0b08;
  }

  .v2-what-is-iris__collab-icon-{{ section.id }} {
    margin-bottom: 1.6rem;
    color: var(--wis-gold);
    font-family: var(--font-heading-family);
    font-size: 2.4rem;
    line-height: 1;
  }

  .v2-what-is-iris__collab-card-title-{{ section.id }} {
    margin: 0 0 1rem;
    color: var(--wis-text);
    font-family: var(--font-heading-family);
    font-size: 2.35rem;
    font-weight: 400;
  }

  .v2-what-is-iris__collab-card-{{ section.id }} p {
    margin: 0;
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.48rem;
    line-height: 1.75;
  }

  .v2-what-is-iris__collab-cta-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 2.8rem;
    margin-top: 4.8rem;
  }

  .v2-what-is-iris__button-gold-{{ section.id }},
  .v2-what-is-iris__button-outline-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-family: var(--font-body-family);
    font-size: 1rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .v2-what-is-iris__button-gold-{{ section.id }} {
    min-width: 25rem;
    padding: 1.8rem 3.6rem;
    background: var(--wis-gold);
    color: var(--wis-black);
  }

  .v2-what-is-iris__button-outline-{{ section.id }} {
    min-width: 25rem;
    padding: 1.7rem 3.6rem;
    border: 1px solid var(--wis-gold-line);
    color: var(--wis-gold);
  }

  .v2-what-is-iris__collab-note-{{ section.id }} {
    color: var(--wis-muted);
    font-family: var(--font-heading-family);
    font-size: 1.45rem;
    font-style: italic;
  }

  .v2-what-is-iris__closing-{{ section.id }} {
    padding: 13rem 5.6rem;
    text-align: center;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__closing-copy-{{ section.id }} {
    max-width: 68rem;
    margin: 0 auto 4.8rem;
  }

  @media screen and (max-width: 1199px) {
    .v2-what-is-iris__split-{{ section.id }},
    .v2-what-is-iris__aesthetics-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .v2-what-is-iris__split-left-{{ section.id }},
    .v2-what-is-iris__aesthetics-left-{{ section.id }} {
      border-right: 0;
      border-bottom: 1px solid var(--wis-border);
    }

    .v2-what-is-iris__aesthetics-right-{{ section.id }},
    .v2-what-is-iris__collab-grid-{{ section.id }},
    .v2-what-is-iris__reveal-steps-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .v2-what-is-iris__collab-grid-{{ section.id }} {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 989px) {
    .v2-what-is-iris__hero-{{ section.id }},
    .v2-what-is-iris__reveal-{{ section.id }},
    .v2-what-is-iris__collab-{{ section.id }},
