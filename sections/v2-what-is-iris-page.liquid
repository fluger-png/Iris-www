        <circle cx="400" cy="140" r="50" stroke="#C9A84C" stroke-width="0.5"/>
        <circle cx="400" cy="140" r="24" stroke="#C9A84C" stroke-width="1.2"/>
        <ellipse cx="378" cy="118" rx="14" ry="9" fill="#C9A84C" opacity="0.25"/>
      </svg>

      <span class="v2-what-is-iris__label-{{ section.id }}">What is IRIS</span>
      <h1 class="v2-what-is-iris__hero-title-{{ section.id }}">Art. Gold.<br><em>Technology.</em></h1>
      <p class="v2-what-is-iris__hero-body-{{ section.id }}">IRIS is a new format for collectible art — where physical gold and digital identity are embedded into every piece. Art you hold. Value you feel. A record that lasts forever.</p>

      <div class="v2-what-is-iris__hero-specs-{{ section.id }}">
        <div class="v2-what-is-iris__hero-spec-{{ section.id }}">
          <div class="v2-what-is-iris__hero-spec-value-{{ section.id }}">4×4&quot;</div>
          <div class="v2-what-is-iris__hero-spec-label-{{ section.id }}">Format</div>
        </div>
        <div class="v2-what-is-iris__hero-spec-{{ section.id }}">
          <div class="v2-what-is-iris__hero-spec-value-{{ section.id }}">0.4g</div>
          <div class="v2-what-is-iris__hero-spec-label-{{ section.id }}">Real gold</div>
        </div>
        <div class="v2-what-is-iris__hero-spec-{{ section.id }}">
          <div class="v2-what-is-iris__hero-spec-value-{{ section.id }}">NFC</div>
          <div class="v2-what-is-iris__hero-spec-label-{{ section.id }}">Chip inside</div>
        </div>
        <div class="v2-what-is-iris__hero-spec-{{ section.id }}">
          <div class="v2-what-is-iris__hero-spec-value-{{ section.id }}">∞</div>
          <div class="v2-what-is-iris__hero-spec-label-{{ section.id }}">Archived forever</div>
        </div>
      </div>

      <div class="v2-what-is-iris__scroll-{{ section.id }}">
        <span>Discover</span>
        <div class="v2-what-is-iris__scroll-line-{{ section.id }}"></div>
      </div>
    </section>

    <section class="v2-what-is-iris__split-{{ section.id }}">
      <div class="v2-what-is-iris__split-left-{{ section.id }}">
        <span class="v2-what-is-iris__label-{{ section.id }}">I — The object</span>
        <h2 class="v2-what-is-iris__split-title-{{ section.id }}">A new kind of collectible object.</h2>
        <div class="v2-what-is-iris__copy-{{ section.id }}">
          <p>IRIS sits at the intersection of contemporary art, physical craft, and material value. Each piece is a framed 4×4 artwork — numbered, sealed, and containing 0.4 grams of real gold embedded into the work itself.</p>
        </div>

        <div class="v2-what-is-iris__spec-list-{{ section.id }}">
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Format</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">4 × 4 inches · archival paper</div></div>
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Finish</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">Hand-finished · framed · sealed</div></div>
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Gold</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">0.4g physical gold · embedded</div></div>
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Numbering</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">Each piece individually numbered</div></div>
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Certificate</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">Included with every piece</div></div>
          <div class="v2-what-is-iris__spec-row-{{ section.id }}"><div class="v2-what-is-iris__spec-key-{{ section.id }}">Shipping</div><div class="v2-what-is-iris__spec-val-{{ section.id }}">Worldwide · protected packaging</div></div>
        </div>
