{%- style -%}
  .v2-what-is-iris-{{ section.id }} {
    --wis-gold: #c9a84c;
    --wis-gold-dim: rgba(201, 168, 76, 0.08);
    --wis-gold-line: rgba(201, 168, 76, 0.2);
    --wis-black: #080808;
    --wis-bg: #0a0a08;
    --wis-ink: #0e0e0c;
    --wis-border: #1e1e1a;
    --wis-text: #e8e4dc;
    --wis-muted: #6a6860;
    --wis-dim: #2e2e2a;
    background: var(--wis-bg);
    color: var(--wis-text);
    position: relative;
    overflow: hidden;
  }

  .v2-what-is-iris-{{ section.id }} *,
  .v2-what-is-iris-{{ section.id }} *::before,
  .v2-what-is-iris-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .v2-what-is-iris-{{ section.id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    z-index: 0;
  }

  .v2-what-is-iris__surface-{{ section.id }} {
    position: relative;
    z-index: 1;
  }

  .v2-what-is-iris__label-{{ section.id }} {
    display: block;
    margin-bottom: 2rem;
    color: var(--wis-gold);
    opacity: 0.55;
    font-size: 0.9rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__gold-em-{{ section.id }} {
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__ticker-{{ section.id }} {
    overflow: hidden;
    white-space: nowrap;
    padding: 1.6rem 0;
    border-top: 1px solid var(--wis-border);
    border-bottom: 1px solid var(--wis-border);
    background: var(--wis-black);
  }

  .v2-what-is-iris__ticker-inner-{{ section.id }} {
    display: inline-flex;
    gap: 6rem;
    min-width: max-content;
    animation: v2WhatIsIrisTicker-{{ section.id }} 28s linear infinite;
  }

  .v2-what-is-iris__ticker-item-{{ section.id }} {
    color: var(--wis-muted);
    font-size: 1.3rem;
    font-style: italic;
    letter-spacing: 0.08rem;
  }

  .v2-what-is-iris__ticker-dot-{{ section.id }} {
    color: var(--wis-gold);
    opacity: 0.4;
  }

  @keyframes v2WhatIsIrisTicker-{{ section.id }} {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .v2-what-is-iris__hero-{{ section.id }} {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12rem 4rem 8rem;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__hero-eye-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(80vw, 110rem);
    opacity: 0.03;
    pointer-events: none;
  }

  .v2-what-is-iris__hero-title-{{ section.id }} {
    margin: 0 0 4.8rem;
    color: var(--wis-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(6rem, 9vw, 13rem);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.3rem;
  }

  .v2-what-is-iris__hero-title-{{ section.id }} em {
    display: block;
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__hero-body-{{ section.id }} {
    max-width: 56rem;
    margin: 0 auto 6.4rem;
    color: var(--wis-muted);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.8rem, 2.2vw, 2.6rem);
    font-style: italic;
    font-weight: 300;
    line-height: 1.7;
  }

  .v2-what-is-iris__hero-specs-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    border: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__hero-spec-{{ section.id }} {
    min-width: 16rem;
    padding: 2rem 4rem;
    text-align: center;
    border-right: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__hero-spec-{{ section.id }}:last-child {
    border-right: 0;
  }

  .v2-what-is-iris__hero-spec-value-{{ section.id }} {
    color: var(--wis-text);
    font-size: 3.2rem;
    line-height: 1;
    letter-spacing: 0.2rem;
  }

  .v2-what-is-iris__hero-spec-label-{{ section.id }} {
    margin-top: 0.6rem;
    color: var(--wis-muted);
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__scroll-{{ section.id }} {
    position: absolute;
    left: 50%;
    bottom: 4rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    animation: v2WhatIsIrisBreathe-{{ section.id }} 2.5s ease-in-out infinite;
  }

  .v2-what-is-iris__scroll-{{ section.id }} span {
    color: var(--wis-muted);
    opacity: 0.3;
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__scroll-line-{{ section.id }} {
    width: 1px;
    height: 3.6rem;
    background: linear-gradient(to bottom, var(--wis-gold), transparent);
    opacity: 0.3;
  }

  @keyframes v2WhatIsIrisBreathe-{{ section.id }} {
    0%, 100% { opacity: 0.5; transform: translateX(-50%) translateY(0); }
    50% { opacity: 1; transform: translateX(-50%) translateY(0.6rem); }
  }

  .v2-what-is-iris__split-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 14rem 5.6rem;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__split-{{ section.id }}--dark {
    background: var(--wis-ink);
  }

  .v2-what-is-iris__split-left-{{ section.id }} {
    padding-right: 8rem;
    border-right: 1px solid var(--wis-border);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .v2-what-is-iris__split-left-{{ section.id }} h2,
  .v2-what-is-iris__aesthetics-title-{{ section.id }},
  .v2-what-is-iris__collab-title-{{ section.id }},
  .v2-what-is-iris__closing-title-{{ section.id }},
  .v2-what-is-iris__reveal-title-{{ section.id }} {
    margin: 0 0 3.2rem;
    color: var(--wis-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(4rem, 4.5vw, 6.4rem);
    font-weight: 300;
    line-height: 1.05;
  }

  .v2-what-is-iris__split-left-{{ section.id }} p,
  .v2-what-is-iris__gold-copy-{{ section.id }} p,
  .v2-what-is-iris__identity-copy-{{ section.id }} p,
  .v2-what-is-iris__aesthetics-copy-{{ section.id }} p,
  .v2-what-is-iris__collab-copy-{{ section.id }} p,
  .v2-what-is-iris__closing-copy-{{ section.id }} {
    margin: 0 0 2rem;
    color: var(--wis-muted);
    font-size: 1.6rem;
    line-height: 1.9;
  }

  .v2-what-is-iris__object-specs-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 4rem;
  }

  .v2-what-is-iris__object-row-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__object-row-{{ section.id }}:first-child {
    border-top: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__object-key-{{ section.id }} {
    width: 12rem;
    flex-shrink: 0;
    color: var(--wis-muted);
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__object-value-{{ section.id }} {
    color: var(--wis-text);
    font-size: 1.4rem;
  }

  .v2-what-is-iris__frame-wrap-{{ section.id }},
  .v2-what-is-iris__gold-visual-{{ section.id }},
  .v2-what-is-iris__identity-visual-{{ section.id }} {
    padding-left: 8rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-what-is-iris__frame-svg-{{ section.id }} {
    width: 100%;
    max-width: 34rem;
  }

  .v2-what-is-iris__rings-wrap-{{ section.id }} {
    position: relative;
    width: 26rem;
    height: 26rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .v2-what-is-iris__ring-{{ section.id }} {
    position: absolute;
    border-radius: 50%;
    border: 1px solid;
    animation: v2WhatIsIrisSpin-{{ section.id }} linear infinite;
  }

  .v2-what-is-iris__ring-{{ section.id }}--one {
    width: 26rem;
    height: 26rem;
    border-color: rgba(201, 168, 76, 0.1);
    animation-duration: 25s;
  }

  .v2-what-is-iris__ring-{{ section.id }}--two {
    width: 19rem;
    height: 19rem;
    border-color: rgba(201, 168, 76, 0.18);
    animation-duration: 18s;
    animation-direction: reverse;
  }

  .v2-what-is-iris__ring-{{ section.id }}--three {
    width: 13rem;
    height: 13rem;
    border-color: rgba(201, 168, 76, 0.3);
    animation-duration: 12s;
  }

  .v2-what-is-iris__sphere-{{ section.id }} {
    width: 7.2rem;
    height: 7.2rem;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #f0d060, #8a5c10);
    box-shadow: 0 0 4.8rem rgba(201, 168, 76, 0.25);
    z-index: 1;
  }

  .v2-what-is-iris__gold-weight-{{ section.id }} {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    text-align: center;
    white-space: nowrap;
  }

  .v2-what-is-iris__gold-weight-num-{{ section.id }} {
    display: block;
    color: var(--wis-gold);
    font-size: 3.2rem;
    letter-spacing: 0.3rem;
  }

  .v2-what-is-iris__gold-weight-label-{{ section.id }} {
    color: var(--wis-muted);
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  @keyframes v2WhatIsIrisSpin-{{ section.id }} {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .v2-what-is-iris__blockquote-{{ section.id }} {
    margin-top: 3.6rem;
    padding-left: 2.4rem;
    border-left: 1px solid var(--wis-gold);
    color: var(--wis-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.1rem;
    font-style: italic;
    line-height: 1.6;
    opacity: 0.8;
  }

  .v2-what-is-iris__identity-visual-{{ section.id }} {
    flex-direction: column;
    gap: 2rem;
    justify-content: center;
  }

  .v2-what-is-iris__card-{{ section.id }} {
    width: 100%;
    max-width: 48rem;
    padding: 2.8rem;
    border: 1px solid var(--wis-border);
    background: var(--wis-ink);
    position: relative;
    overflow: hidden;
  }

  .v2-what-is-iris__card-{{ section.id }}::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--wis-gold), transparent);
    opacity: 0.4;
  }

  .v2-what-is-iris__card-label-{{ section.id }} {
    margin-bottom: 1.6rem;
    color: var(--wis-gold);
    opacity: 0.5;
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__card-title-{{ section.id }} {
    margin: 0 0 0.8rem;
    color: var(--wis-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.2rem;
    font-style: italic;
    font-weight: 300;
  }

  .v2-what-is-iris__card-meta-{{ section.id }} {
    margin-bottom: 1.6rem;
    color: var(--wis-muted);
    font-size: 1.4rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__card-body-{{ section.id }} {
    color: var(--wis-muted);
    font-size: 1.2rem;
    line-height: 1.7;
  }

  .v2-what-is-iris__scan-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: 1.2rem;
  }

  .v2-what-is-iris__scan-dot-{{ section.id }} {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: #4caf7d;
    animation: v2WhatIsIrisPulse-{{ section.id }} 2s ease-in-out infinite;
  }

  @keyframes v2WhatIsIrisPulse-{{ section.id }} {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .v2-what-is-iris__scan-label-{{ section.id }} {
    color: #4caf7d;
    font-size: 1rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__archive-card-{{ section.id }} {
    background: var(--wis-gold-dim);
    border-color: var(--wis-gold-line);
  }

  .v2-what-is-iris__archive-row-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    color: var(--wis-muted);
    font-size: 1.2rem;
  }

  .v2-what-is-iris__archive-row-{{ section.id }}:last-child {
    border-bottom: 0;
  }

  .v2-what-is-iris__archive-row-{{ section.id }} span {
    color: var(--wis-text);
  }

  .v2-what-is-iris__reveal-{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: 16rem 5.6rem;
    text-align: center;
    border-bottom: 1px solid var(--wis-border);
    background: var(--wis-black);
  }

  .v2-what-is-iris__reveal-watermark-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: transparent;
    -webkit-text-stroke: 1px rgba(201, 168, 76, 0.04);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(16rem, 22vw, 32rem);
    font-style: italic;
    font-weight: 300;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .v2-what-is-iris__reveal-title-{{ section.id }} em {
    display: block;
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__reveal-rule-{{ section.id }} {
    width: 1px;
    height: 5.6rem;
    margin: 4.8rem auto;
    background: linear-gradient(to bottom, transparent, var(--wis-gold), transparent);
    opacity: 0.4;
  }

  .v2-what-is-iris__reveal-body-{{ section.id }} {
    max-width: 64rem;
    margin: 0 auto 6rem;
    color: var(--wis-muted);
    font-size: 1.7rem;
    line-height: 1.9;
  }

  .v2-what-is-iris__reveal-steps-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--wis-border);
  }

  .v2-what-is-iris__reveal-step-{{ section.id }} {
    padding: 4.4rem 3.6rem;
    background: var(--wis-bg);
    text-align: left;
  }

  .v2-what-is-iris__reveal-step-{{ section.id }}--highlight {
    background: #0f0d08;
  }

  .v2-what-is-iris__reveal-num-{{ section.id }} {
    margin-bottom: 1.6rem;
    color: var(--wis-dim);
    font-size: 5.2rem;
    line-height: 1;
  }

  .v2-what-is-iris__reveal-step-title-{{ section.id }} {
    margin-bottom: 1.2rem;
    color: var(--wis-text);
    font-size: 1.1rem;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__reveal-step-{{ section.id }}--highlight .v2-what-is-iris__reveal-step-title-{{ section.id }} {
    color: var(--wis-gold);
  }

  .v2-what-is-iris__reveal-step-{{ section.id }} p {
    margin: 0;
    color: var(--wis-muted);
    font-size: 1.4rem;
    line-height: 1.8;
  }

  .v2-what-is-iris__aesthetics-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 14rem 5.6rem;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__aesthetics-left-{{ section.id }} {
    padding-right: 8rem;
    border-right: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__aesthetics-thoughts-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 3.2rem;
    padding-left: 8rem;
  }

  .v2-what-is-iris__thought-marker-{{ section.id }} {
    margin-bottom: 1.2rem;
    color: var(--wis-gold);
    opacity: 0.4;
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  .v2-what-is-iris__thought-{{ section.id }} p em {
    color: var(--wis-gold);
    font-style: italic;
  }

  .v2-what-is-iris__collab-{{ section.id }} {
    padding: 14rem 5.6rem;
    border-bottom: 1px solid var(--wis-border);
  }

  .v2-what-is-iris__collab-header-{{ section.id }} {
    max-width: 72rem;
    margin-bottom: 5.6rem;
  }

  .v2-what-is-iris__collab-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--wis-border);
  }

  .v2-what-is-iris__collab-card-{{ section.id }} {
    background: var(--wis-bg);
    padding: 4rem 3.2rem;
    position: relative;
  }

  .v2-what-is-iris__collab-card-{{ section.id }}--featured::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--wis-gold);
  }

  .v2-what-is-iris__collab-icon-{{ section.id }} {
    margin-bottom: 2rem;
    color: var(--wis-muted);
    font-size: 2.8rem;
    line-height: 1;
  }

  .v2-what-is-iris__collab-card-{{ section.id }}--featured .v2-what-is-iris__collab-icon-{{ section.id }} {
    color: var(--wis-gold);
  }

  .v2-what-is-iris__collab-card-{{ section.id }} h3 {
    margin: 0 0 1.2rem;
    color: var(--wis-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.4rem;
    font-weight: 300;
  }

  .v2-what-is-iris__collab-card-{{ section.id }} p {
    margin: 0;
    color: var(--wis-muted);
    font-size: 1.4rem;
    line-height: 1.8;
  }

  .v2-what-is-iris__collab-cta-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 3.2rem;
    margin-top: 6rem;
  }

  .v2-what-is-iris__button-gold-{{ section.id }},
  .v2-what-is-iris__button-outline-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    text-decoration: none;
    font-size: 1rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  .v2-what-is-iris__button-gold-{{ section.id }} {
    padding: 1.6rem 4rem;
    background: var(--wis-gold);
    color: var(--wis-black);
  }

  .v2-what-is-iris__button-gold-{{ section.id }}:hover {
    background: #e8c96a;
    gap: 2rem;
  }

  .v2-what-is-iris__button-outline-{{ section.id }} {
    padding: 1.4rem 3.6rem;
    border: 1px solid var(--wis-gold-line);
    color: var(--wis-gold);
  }

  .v2-what-is-iris__button-outline-{{ section.id }}:hover {
    background: var(--wis-gold-dim);
    gap: 2rem;
  }

  .v2-what-is-iris__collab-note-{{ section.id }} {
    color: var(--wis-muted);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.3rem;
    font-style: italic;
  }

  .v2-what-is-iris__closing-{{ section.id }} {
    padding: 14rem 5.6rem;
    border-bottom: 1px solid var(--wis-border);
    text-align: center;
  }

  .v2-what-is-iris__closing-title-{{ section.id }} em {
    color: var(--wis-gold);
