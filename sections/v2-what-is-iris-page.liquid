            class="v2-what-is-iris__object-image-{{ section.id }} v2-what-is-iris__object-image-{{ section.id }}--bleed"
            src="https://cdn.shopify.com/s/files/1/0710/5239/4589/files/faq-banner.png?v=1770948543"
            alt="IRIS gold detail"
            loading="lazy"
          >
          <div class="v2-what-is-iris__gold-overlay-{{ section.id }}">
            <div class="v2-what-is-iris__gold-overlay-badge-{{ section.id }}">Au 79</div>
            <div class="v2-what-is-iris__gold-overlay-weight-{{ section.id }}">0.4g</div>
            <div class="v2-what-is-iris__gold-overlay-meta-{{ section.id }}">Physical gold · per piece · live price</div>
          </div>
        </div>
      </div>

      <div class="v2-what-is-iris__split-right-copy-{{ section.id }}">
        <span class="v2-what-is-iris__label-{{ section.id }}">II — The gold</span>
        <h2 class="v2-what-is-iris__split-title-{{ section.id }}">Every IRIS contains 0.4 grams of physical gold.</h2>
        <div class="v2-what-is-iris__copy-{{ section.id }}">
          <p>Each IRIS contains 0.4 grams of physical gold embedded into the artwork itself. Gold has held value for five thousand years. Hang it on your wall, place it on a shelf, or keep it with the things you consider worth keeping. Either way, the gold is there.</p>
        </div>
      </div>
    </section>

    <section class="v2-what-is-iris__split-{{ section.id }} v2-what-is-iris__identity-shell-{{ section.id }}" id="V2WhatIsIrisIdentitySection-{{ section.id }}">
