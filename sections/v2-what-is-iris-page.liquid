            alt="IRIS object preview"
            loading="lazy"
          >
        </div>
      </div>
    </section>

    <section class="v2-what-is-iris__split-{{ section.id }} v2-what-is-iris__split-{{ section.id }}--dark">
      <div class="v2-what-is-iris__visual-{{ section.id }} v2-what-is-iris__visual-{{ section.id }}--bleed">
