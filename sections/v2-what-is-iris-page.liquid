        <div class="v2-what-is-iris__object-image-frame-{{ section.id }} v2-what-is-iris__object-image-frame-{{ section.id }}--bleed">
          <img
            class="v2-what-is-iris__object-image-{{ section.id }} v2-what-is-iris__object-image-{{ section.id }}--bleed"
