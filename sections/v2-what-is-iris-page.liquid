    .v2-what-is-iris__button-gold-{{ section.id }},
    .v2-what-is-iris__button-outline-{{ section.id }} {
      min-width: 0;
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="v2-what-is-iris-{{ section.id }}">
  <div class="v2-what-is-iris__surface-{{ section.id }}">
